C.1 ICA Preprocessing Module (Python)

```python
import numpy as np
from scipy.signal import savgol_filter, find_peaks, peak_widths
from scipy.interpolate import interp1d
from scipy.integrate import trapz

def compute_ica(voltage, current, time, voltage_grid, sg_window=51, sg_order=3):
    """
    Compute Incremental Capacity curve for a single charge cycle.
    
    Parameters:
        voltage: array of voltage measurements during charge
        current: array of current measurements
        time: array of time stamps
        voltage_grid: 1D array of target voltages for resampling
        sg_window, sg_order: Savitzky-Golay parameters
    
    Returns:
        V_ic: voltage centers (length M-1)
        IC_smooth: smoothed IC curve
        peak_features: dict with 'position', 'height', 'area' or None if no peak
    """
    # Compute capacity Q = ∫ I dt
    dt = np.diff(time)
    Q = np.cumsum(current[:-1] * dt)
    V_charge = voltage[:-1]  # align with Q
    
    # Resample Q onto voltage_grid
    interp_func = interp1d(V_charge, Q, kind='linear', bounds_error=False, fill_value='extrapolate')
    Q_grid = interp_func(voltage_grid)
    
    # Compute raw IC
    dV = np.diff(voltage_grid)
    dQ = np.diff(Q_grid)
    IC_raw = dQ / dV
    V_ic = voltage_grid[:-1]
    
    # Smooth IC
    IC_smooth = savgol_filter(IC_raw, window_length=sg_window, polyorder=sg_order)
    
    # Find peaks
    peaks, properties = find_peaks(IC_smooth, height=0)
    peak_features = None
    if len(peaks) > 0:
        # Take highest peak
        main_idx = peaks[np.argmax(properties['peak_heights'])]
        height = properties['peak_heights'][np.argmax(properties['peak_heights'])]
        position = V_ic[main_idx]
        # Compute width at half height and area
        widths = peak_widths(IC_smooth, [main_idx], rel_height=0.5)
        left = int(np.round(widths[2][0]))
        right = int(np.round(widths[3][0]))
        area = trapz(IC_smooth[left:right+1], V_ic[left:right+1])
        peak_features = {'position': position, 'height': height, 'area': area}
    
    return V_ic, IC_smooth, peak_features
```

C.2 CNN‑Transformer Model Definition (PyTorch)

```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class CNNTransformerSOH(nn.Module):
    def __init__(self, input_dim, d_model=128, nhead=8, num_layers=4, 
                 cnn_channels=[64, 128], kernel_size=5, dropout=0.1):
        super().__init__()
        self.input_proj = nn.Linear(input_dim, cnn_channels[0])
        
        # CNN layers
        cnn_layers = []
        in_ch = cnn_channels[0]
        for out_ch in cnn_channels[1:]:
            cnn_layers.append(nn.Conv1d(in_ch, out_ch, kernel_size, padding=kernel_size//2))
            cnn_layers.append(nn.BatchNorm1d(out_ch))
            cnn_layers.append(nn.ReLU())
            in_ch = out_ch
        self.cnn = nn.Sequential(*cnn_layers)
        
        # Project to d_model for Transformer
        self.cnn_proj = nn.Linear(cnn_channels[-1], d_model)
        
        # Positional encoding (learned)
        self.pos_encoder = nn.Embedding(1000, d_model)  # max sequence length 1000
        
        # Transformer encoder
        encoder_layer = nn.TransformerEncoderLayer(d_model=d_model, nhead=nhead,
                                                    dim_feedforward=d_model*4,
                                                    dropout=dropout, batch_first=True)
        self.transformer = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)
        
        # Output head
        self.soh_head = nn.Linear(d_model, 1)
        self.dropout = nn.Dropout(dropout)
        
    def forward(self, x, mask=None):
        # x: (batch, seq_len, input_dim)
        batch_size, seq_len, _ = x.shape
        
        # CNN expects (batch, channels, seq_len)
        x = self.input_proj(x)  # (batch, seq_len, c0)
        x = x.transpose(1, 2)   # (batch, c0, seq_len)
        x = self.cnn(x)          # (batch, c_out, seq_len)
        x = x.transpose(1, 2)   # (batch, seq_len, c_out)
        x = self.cnn_proj(x)     # (batch, seq_len, d_model)
        
        # Add positional encoding
        positions = torch.arange(seq_len, device=x.device).unsqueeze(0)
        x = x + self.pos_encoder(positions)
        
        # Transformer (mask can be used to ignore padded positions)
        x = self.transformer(x, src_key_padding_mask=mask)  # (batch, seq_len, d_model)
        
        # Use the last valid time step or mean over valid steps
        if mask is not None:
            # mask is True for padding, invert to get valid
            valid = ~mask
            # Take mean over valid time steps
            x = (x * valid.unsqueeze(-1)).sum(dim=1) / valid.sum(dim=1, keepdim=True)
        else:
            x = x.mean(dim=1)   # global average pooling
        
        x = self.dropout(x)
        soh = torch.sigmoid(self.soh_head(x)).squeeze(-1)
        return soh
```

C.3 Custom Loss Functions

```python
class BatteryLoss(nn.Module):
    def __init__(self, lambda_mono=0.1, lambda_ecm=0.05, R_nom=0.02, gamma_init=1.0):
        super().__init__()
        self.lambda_mono = lambda_mono
        self.lambda_ecm = lambda_ecm
        self.R_nom = R_nom
        self.gamma = nn.Parameter(torch.tensor(gamma_init, dtype=torch.float32))
        
    def forward(self, soh_pred, soh_target, mono_mask, current, voltage, ocv, valid_mask):
        """
        Args:
            soh_pred: (batch, seq_len) predicted SOH
            soh_target: (batch, seq_len) ground truth
            mono_mask: (batch, seq_len-1) mask for monotonicity (1 if should be non-increasing)
            current: (batch, seq_len, num_points) current values for each cycle
            voltage: (batch, seq_len, num_points) measured voltage
            ocv: (batch, seq_len, num_points) open-circuit voltage (from SOC lookup)
            valid_mask: (batch, seq_len) 1 for valid cycles
        """
        # Data loss
        data_loss = F.mse_loss(soh_pred[valid_mask], soh_target[valid_mask])
        
        # Monotonicity loss
        diff = soh_pred[:, 1:] - soh_pred[:, :-1]  # (batch, seq_len-1)
        mono_loss = (mono_mask * F.relu(diff)).mean()
        
        # ECM loss
        # Expand soh_pred to match current points: (batch, seq_len, 1) -> (batch, seq_len, num_points)
        soh_expanded = soh_pred.unsqueeze(-1).expand(-1, -1, current.shape[-1])
        R = self.R_nom * torch.exp(self.gamma * (1 - soh_expanded))
        v_pred = ocv - current * R
        error = (voltage - v_pred) ** 2
        # Only consider points with significant current
        current_mask = (torch.abs(current) > 1e-3).float()
        ecm_loss = (error * current_mask).sum() / (current_mask.sum() + 1e-8)
        
        total_loss = data_loss + self.lambda_mono * mono_loss + self.lambda_ecm * ecm_loss
        return total_loss, data_loss, mono_loss, ecm_loss
```

C.4 Uncertainty Quantification with MC Dropout

```python
def mc_dropout_predict(model, x, mask, num_samples=50):
    """
    Perform Monte Carlo Dropout prediction.
    
    Returns:
        mean: (batch, seq_len) predictive mean
        variance: (batch, seq_len) predictive variance
        samples: (num_samples, batch, seq_len) all samples
    """
    model.train()  # enable dropout
    samples = []
    with torch.no_grad():
        for _ in range(num_samples):
            out = model(x, mask)
            samples.append(out.cpu().numpy())
    samples = np.array(samples)  # (num_samples, batch, seq_len)
    mean = samples.mean(axis=0)
    variance = samples.var(axis=0)
    return mean, variance, samples
```

