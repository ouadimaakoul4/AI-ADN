C.4 Implementation Sketch for LipSwish Contractive Decorator

```python
import torch
import torch.nn as nn

class LipSwish(nn.Module):
    """1-Lipschitz activation: x * sigmoid(beta*x) with beta chosen so that derivative ≤ 1."""
    def __init__(self, beta=1.0):
        super().__init__()
        self.beta = nn.Parameter(torch.tensor(beta))
        self.register_buffer('max_beta', torch.tensor(1.0))  # ensure derivative ≤ 1

    def forward(self, x):
        # Ensure beta is at most max_beta (or train with constraint)
        beta_clamped = torch.clamp(self.beta, max=self.max_beta)
        return x * torch.sigmoid(beta_clamped * x)

class ContractiveDecorator(nn.Module):
    """Wraps a neural network to enforce global Lipschitz constant ≤ 1 and train for contraction."""
    def __init__(self, model, contraction_target=0.99):
        super().__init__()
        self.model = model
        self.contraction_target = contraction_target

        # Replace activations with 1-Lipschitz versions
        self.replace_activations(model)

        # Apply spectral normalization to all linear layers
        self.apply_spectral_norm(model)

    def replace_activations(self, module):
        for name, child in module.named_children():
            if isinstance(child, nn.ReLU):
                setattr(module, name, LipSwish())
            else:
                self.replace_activations(child)

    def apply_spectral_norm(self, module):
        for name, child in module.named_children():
            if isinstance(child, nn.Linear):
                setattr(module, name, nn.utils.spectral_norm(child))
            else:
                self.apply_spectral_norm(child)

    def forward(self, x):
        return self.model(x)

    def train_with_contraction(self, data_loader, epochs, optimizer):
        # Training loop with additional contraction regularization
        for epoch in range(epochs):
            for x, y in data_loader:
                optimizer.zero_grad()
                output = self.model(x)
                loss = nn.MSELoss()(output, y)

                # Compute Jacobian spectral radius penalty (approximate)
                if self.training:
                    jacobian = torch.autograd.functional.jacobian(self.model, x)
                    # Compute spectral radius (power method) and add penalty
                    loss += 0.01 * self.spectral_radius(jacobian)

                loss.backward()
                optimizer.step()
