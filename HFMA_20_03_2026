```python
def tendon_visibility(design):
    """
    design: object with list of tendons, each with:
        - segments: list of segments, each with length, visible (bool), sheath_opacity (if any)
    """
    total_len = 0
    visible_len = 0
    opacity_sum = 0
    opacity_count = 0
    for tendon in design.tendons:
        for seg in tendon.segments:
            total_len += seg.length
            if seg.visible:
                visible_len += seg.length
            if hasattr(seg, 'sheath_opacity'):
                opacity_sum += seg.sheath_opacity
                opacity_count += 1
    avg_opacity = opacity_sum / opacity_count if opacity_count > 0 else 0
    TVI = (visible_len / total_len) / (1 + avg_opacity)
    return TVI

def articulation_exposure(design):
    """
    design: list of joints, each with:
        - total_dof: int (1 or 2 typically)
        - exposed_dof: int (how many visibly articulated)
        - importance: weight
    """
    numer = sum(j.exposed_dof * j.importance for j in design.joints)
    denom = sum(j.total_dof * j.importance for j in design.joints)
    return numer / denom if denom > 0 else 0

def force_flow_clarity(design):
    """
    design: tendons and pulleys
    """
    total_curv = 0
    num_seg = 0
    for tendon in design.tendons:
        for seg in tendon.segments:
            total_curv += seg.curvature  # assume curvature integrated over length
            num_seg += 1
    avg_curv = total_curv / num_seg if num_seg > 0 else 0
    hidden_guides = sum(1 for pulley in design.pulleys if pulley.hidden)
    FFC = 1 / (1 + avg_curv + hidden_guides)
    return FFC
