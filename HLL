```python
class UKF:
    def __init__(self, dt, alpha=1e-3, beta=2, kappa=0):
        """
        Unscented Kalman Filter for lander state estimation
        
        State: [x, y, z, vx, vy, vz, q0, q1, q2, q3, ba_x, ba_y, ba_z, bg_x, bg_y, bg_z]
        """
        self.n = 16  # state dimension
        self.dt = dt
        
        # UKF parameters
        self.alpha = alpha
        self.beta = beta
        self.kappa = kappa
        self.lamb = alpha**2 * (self.n + kappa) - self.n
        
        # Weights
        self.Wm = np.zeros(2*self.n + 1)
        self.Wc = np.zeros(2*self.n + 1)
        self.Wm[0] = self.lamb / (self.n + self.lamb)
        self.Wc[0] = self.Wm[0] + (1 - alpha**2 + beta)
        for i in range(1, 2*self.n + 1):
            self.Wm[i] = 1 / (2*(self.n + self.lamb))
            self.Wc[i] = self.Wm[i]
        
        # Process noise covariance
        self.Q = np.eye(self.n) * 1e-6
        self.Q[6:10, 6:10] *= 1e-8  # quaternion noise small
        
        # Measurement noise (set dynamically)
        self.R = None
    
    def generate_sigma_points(self, x, P):
        """Generate sigma points around current estimate"""
        sigma_points = np.zeros((2*self.n + 1, self.n))
        sigma_points[0, :] = x
        
        # Matrix square root
        try:
            sqrt_P = np.linalg.cholesky((self.n + self.lamb) * P)
        except:
            sqrt_P = np.linalg.cholesky((self.n + self.lamb) * P + 1e-6 * np.eye(self.n))
        
        for i in range(self.n):
            sigma_points[i+1, :] = x + sqrt_P[:, i]
            sigma_points[self.n + i + 1, :] = x - sqrt_P[:, i]
        
        return sigma_points
    
    def predict(self, x, P, a_meas, omega_meas):
        """Prediction step using IMU measurements"""
        sigma_points = self.generate_sigma_points(x, P)
        sigma_points_pred = np.zeros_like(sigma_points)
        
        for i in range(2*self.n + 1):
            sigma_points_pred[i, :] = self.dynamics(
                sigma_points[i, :], a_meas, omega_meas, self.dt)
        
        # Predicted mean
        x_pred = np.sum(self.Wm[:, np.newaxis] * sigma_points_pred, axis=0)
        
        # Predicted covariance
        P_pred = np.zeros((self.n, self.n))
        for i in range(2*self.n + 1):
            diff = sigma_points_pred[i, :] - x_pred
            P_pred += self.Wc[i] * np.outer(diff, diff)
        P_pred += self.Q
        
        return x_pred, P_pred, sigma_points_pred
    
    def update(self, x_pred, P_pred, sigma_points_pred, z, measurement_type):
        """Update step using measurement"""
        # Set measurement noise based on type
        if measurement_type == 'gicp':
            self.R = np.eye(3) * 0.01**2  # 1 cm position update
            h = self.h_gicp
            nz = 3
        elif measurement_type == 'radar':
            self.R = np.eye(1) * 0.1**2  # 10 cm altitude update
            h = self.h_radar
            nz = 1
        else:
            raise ValueError(f"Unknown measurement type: {measurement_type}")
        
        # Transform sigma points to measurement space
        Z = np.zeros((2*self.n + 1, nz))
        for i in range(2*self.n + 1):
            Z[i, :] = h(sigma_points_pred[i, :])
        
        # Predicted measurement
        z_pred = np.sum(self.Wm[:, np.newaxis] * Z, axis=0)
        
        # Innovation covariance
        P_zz = np.zeros((nz, nz))
        for i in range(2*self.n + 1):
            diff_z = Z[i, :] - z_pred
            P_zz += self.Wc[i] * np.outer(diff_z, diff_z)
        P_zz += self.R
        
        # Cross covariance
        P_xz = np.zeros((self.n, nz))
        for i in range(2*self.n + 1):
            diff_x = sigma_points_pred[i, :] - x_pred
            diff_z = Z[i, :] - z_pred
            P_xz += self.Wc[i] * np.outer(diff_x, diff_z)
        
        # Kalman gain
        K = P_xz @ np.linalg.inv(P_zz)
        
        # Update
        innovation = z - z_pred
        x_updated = x_pred + K @ innovation
        P_updated = P_pred - K @ P_zz @ K.T
        
        return x_updated, P_updated, innovation
    
    def dynamics(self, state, a_meas, omega_meas, dt):
        """State dynamics with IMU measurements"""
        p = state[0:3]
        v = state[3:6]
        q = state[6:10]
        ba = state[10:13]
        bg = state[13:16]
        
        # Correct measurements with biases
        a_corrected = a_meas - ba
        omega_corrected = omega_meas - bg
        
        # Update position
        p_new = p + v*dt + 0.5*a_corrected*dt**2
        
        # Update velocity
        v_new = v + a_corrected*dt + g_m*dt
        
        # Update attitude (quaternion integration)
        omega_norm = np.linalg.norm(omega_corrected)
        if omega_norm > 1e-10:
            delta_q = np.array([
                np.cos(omega_norm*dt/2),
                omega_corrected[0]/omega_norm * np.sin(omega_norm*dt/2),
                omega_corrected[1]/omega_norm * np.sin(omega_norm*dt/2),
                omega_corrected[2]/omega_norm * np.sin(omega_norm*dt/2)
            ])
            q_new = quaternion_multiply(q, delta_q)
            q_new = q_new / np.linalg.norm(q_new)
        else:
            q_new = q
        
        # Biases (random walk)
        ba_new = ba
        bg_new = bg
        
        return np.concatenate([p_new, v_new, q_new, ba_new, bg_new])
    
    def h_gicp(self, state):
        """Measurement function for G-ICP (position only)"""
        return state[0:3]
    
    def h_radar(self, state):
        """Measurement function for radar (altitude)"""
        return np.array([state[2]])  # z-coordinate
