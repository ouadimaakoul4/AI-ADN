\int_V \nabla \cdot \mathbf{A} \, dV = \oint_S \mathbf{A} \cdot \mathbf{n} \, dS \quad \text{(Divergence Theorem)}

\int_S (\nabla \times \mathbf{A}) \cdot \mathbf{n} \, dS = \oint_C \mathbf{A} \cdot d\mathbf{l} \quad \text{(Stokes' Theorem)}

