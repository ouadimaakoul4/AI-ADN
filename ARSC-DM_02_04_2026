import torch
from torch.autograd.functional import jacobian

def huber_influence(r, alpha=1.0):
    """Huber influence function psi(r) = max(-alpha, min(r, alpha))."""
    return torch.clamp(r, -alpha, alpha)

class MIEKF:
    def __init__(self, f, h, Q, R, alpha_huber=1.0):
        self.f = f          # state transition function
        self.h = h          # measurement function
        self.Q = Q          # process noise covariance
        self.R = R          # measurement noise covariance
        self.alpha = alpha_huber
        
    def step(self, x_pred, P_pred, y, max_iter=10, tol=1e-8):
        """
        MIEKF update using semismooth Newton.
        Returns: x_upd, P_upd
        """
        x = x_pred.clone()
        for _ in range(max_iter):
            # Linearize measurement at current x
            H = jacobian(self.h, x).squeeze(0)
            # Compute residuals
            r = y - self.h(x)
            # Influence function and its derivative (subgradient)
            psi = huber_influence(r, self.alpha)
            # Diagonal matrix D with entries psi'(r_i)
            D = torch.diag((torch.abs(r) <= self.alpha).float())
            # Kalman gain
            S = H @ P_pred @ H.T + self.R
            K = P_pred @ H.T @ torch.linalg.solve(S, torch.eye(len(y)))
            # Fixed-point map F(x) = x - x_pred - K * psi(r)
            F = x - x_pred - K @ psi
            # B-subdifferential element: I + K * D * H
            V = torch.eye(len(x)) + K @ D @ H
            # Newton step
            dx = torch.linalg.solve(V, -F)
            x_new = x + dx
            if torch.norm(dx) < tol:
                break
            x = x_new
        # Update covariance
        P_upd = (torch.eye(len(x)) - K @ D @ H) @ P_pred
        return x, P_upd

