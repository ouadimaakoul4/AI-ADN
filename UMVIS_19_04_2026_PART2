D.7 CLUB Estimator Update

```python
class CLUBEstimator(nn.Module):
    """Contrastive Log-ratio Upper Bound estimator for conditional MI."""
    
    def __init__(self, x_dim, y_dim, hidden_dim=256):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(x_dim + y_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, hidden_dim),
            nn.ReLU(),
            nn.Linear(hidden_dim, y_dim * 2)  # mean and logvar for Gaussian
        )
    
    def log_prob(self, y, x):
        """Compute log q(y|x)."""
        params = self.net(torch.cat([x, y], dim=-1))
        mean, logvar = params.chunk(2, dim=-1)
        # Gaussian log-likelihood
        log_prob = -0.5 * (logvar + ((y - mean)**2) / torch.exp(logvar) + math.log(2*math.pi))
        return log_prob.sum(dim=-1)  # sum over y dimensions
    
    def club_loss(self, y, x, y_shuffle=None, x_shuffle=None):
        """
        Compute CLUB loss: E_{p(x,y)}[log q(y|x)] - E_{p(x)p(y)}[log q(y|x)]
        """
        # Positive samples
        pos = self.log_prob(y, x).mean()
        
        # Negative samples (shuffled)
        if y_shuffle is None:
            y_shuffle = y[torch.randperm(y.size(0))]
        if x_shuffle is None:
            x_shuffle = x[torch.randperm(x.size(0))]
        neg = self.log_prob(y_shuffle, x_shuffle).mean()
        
        return pos - neg
```

