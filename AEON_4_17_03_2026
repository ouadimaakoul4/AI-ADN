    (e : G) : M → IntentionalMonad M G :=
  λ m => (m, e)

def mult {M G} [LieGroup G] : IntentionalMonad (IntentionalMonad M G) G → IntentionalMonad M G :=
  λ ((m, g1), g2) => (m, g1 * g2)

-- Monad laws
theorem unit_left {M G} [LieGroup G] (m : M) (g : G) :
    mult (unit e (m, g)) = (m, g) := by
  simp [unit, mult, mul_one]

theorem unit_right {M G} [LieGroup G] (m : M) (g : G) :
    mult ((m, g), e) = (m, g) := by
  simp [mult, mul_one]

theorem associativity {M G} [LieGroup G] (m : M) (g1 g2 g3 : G) :
    mult (mult ((m, g1), g2), g3) = mult ((m, g1), g2 * g3) := by
  simp [mult, mul_assoc]
