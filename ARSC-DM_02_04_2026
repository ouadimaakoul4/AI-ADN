import torch
import torch.nn as nn
import torch.optim as optim
from torch.distributions import Normal, kl_divergence
import math

class PAC_Bayesian_PINN(nn.Module):
    """
    Physics-Informed Neural Network with PAC-Bayesian generalization bound.
    Implements randomized collocation and variational approximation for KL.
    """
    def __init__(self, layers, prior_std=1.0, device='cuda'):
        super().__init__()
        self.layers = nn.ModuleList()
        self.prior_std = prior_std
        self.device = device
        
        # Build network with variational parameters (mean and log-variance)
        for i in range(len(layers)-1):
            in_dim, out_dim = layers[i], layers[i+1]
            self.layers.append(nn.Linear(in_dim, out_dim))
            
        # Variational parameters: mean and log_sigma for each weight and bias
        self.weight_means = nn.ParameterList()
        self.weight_logvars = nn.ParameterList()
        for layer in self.layers:
            self.weight_means.append(nn.Parameter(layer.weight.data.clone()))
            self.weight_logvars.append(nn.Parameter(torch.full_like(layer.weight, -5.0)))
            self.weight_means.append(nn.Parameter(layer.bias.data.clone()))
            self.weight_logvars.append(nn.Parameter(torch.full_like(layer.bias, -5.0)))
    
    def reparameterize(self):
        """Sample weights from variational posterior using reparameterization trick."""
        sampled_weights = []
        idx = 0
        for layer in self.layers:
            w_mean = self.weight_means[idx]; w_logvar = self.weight_logvars[idx]; idx+=1
            b_mean = self.weight_means[idx]; b_logvar = self.weight_logvars[idx]; idx+=1
            eps_w = torch.randn_like(w_mean)
            eps_b = torch.randn_like(b_mean)
            w = w_mean + torch.exp(0.5 * w_logvar) * eps_w
            b = b_mean + torch.exp(0.5 * b_logvar) * eps_b
            sampled_weights.append((w, b))
        return sampled_weights
    
    def forward(self, x, weights=None):
        if weights is None:
            weights = self.reparameterize()
        for (w, b), layer in zip(weights, self.layers):
            x = torch.nn.functional.linear(x, w, b)
            x = torch.nn.functional.silu(x)  # Swish activation
        return x
    
    def kl_divergence(self):
        """Compute KL(Q||P) for the variational posterior."""
        kl = 0.0
        prior = Normal(0.0, self.prior_std)
        idx = 0
        for layer in self.layers:
            w_mean = self.weight_means[idx]; w_logvar = self.weight_logvars[idx]; idx+=1
            b_mean = self.weight_means[idx]; b_logvar = self.weight_logvars[idx]; idx+=1
            q_w = Normal(w_mean, torch.exp(0.5 * w_logvar))
            q_b = Normal(b_mean, torch.exp(0.5 * b_logvar))
            kl += kl_divergence(q_w, prior).sum()
            kl += kl_divergence(q_b, prior).sum()
        return kl

def pde_residual(model, x, t, w_mesh, kappa, rho_cp, q_pyro, q_abl):
    """
    Compute ALE heat equation residual.
    x: spatial coordinates (N, 3), t: time (N,1), w_mesh: mesh velocity (N,3)
    """
    x.requires_grad_(True)
    t.requires_grad_(True)
    u = model(torch.cat([x, t], dim=1))
    # Gradients
    u_x = torch.autograd.grad(u, x, grad_outputs=torch.ones_like(u), create_graph=True)[0]
    u_t = torch.autograd.grad(u, t, grad_outputs=torch.ones_like(u), create_graph=True)[0]
    u_xx = torch.autograd.grad(u_x, x, grad_outputs=torch.ones_like(u_x), create_graph=True)[0]
    # Residual
    residual = rho_cp * (u_t + (w_mesh * u_x).sum(dim=1, keepdim=True)) - kappa * u_xx.sum(dim=1, keepdim=True) - q_pyro(u) + q_abl(u)
    return residual

def rte_residual(model, s, lam, kappa_gas, B_lambda, T_vib):
    """
    Compute non-LTE radiative transfer residual (simplified 1D).
    s: ray coordinate, lam: wavelength.
    """
    # In practice, this would call an MRT-LBM solver.
    # Placeholder: return zero for demonstration.
    return torch.zeros_like(s)

def train_pinn(model, data_loader, collocation_points, lambda_pde, mu_rte, lr=1e-3, epochs=100):
    optimizer = optim.Adam(model.parameters(), lr=lr)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, patience=10)
    
    for epoch in range(epochs):
        model.train()
        total_loss = 0.0
        for batch in data_loader:
            x_data, t_data, y_data = batch
            # Data loss
            u_pred = model(torch.cat([x_data, t_data], dim=1))
            loss_data = torch.nn.functional.mse_loss(u_pred, y_data)
            
            # PDE loss on random collocation points
            x_coll, t_coll, w_coll = collocation_points
            res_pde = pde_residual(model, x_coll, t_coll, w_coll, ...)  # fill with actual coefficients
            loss_pde = res_pde.pow(2).mean()
            
            # RTE loss
            res_rte = rte_residual(model, ...)
            loss_rte = res_rte.pow(2).mean()
            
            # KL term
            kl = model.kl_divergence() / len(data_loader.dataset)
            
            # Total PINN loss
            loss = loss_data + lambda_pde * loss_pde + mu_rte * loss_rte + kl
            
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            total_loss += loss.item()
        
        scheduler.step(total_loss)
        if epoch % 10 == 0:
            print(f"Epoch {epoch}: Loss = {total_loss:.4e}, KL = {kl.item():.4e}")
    
    # After training, compute PAC-Bayesian bound
    final_kl = model.kl_divergence().item()
    N = len(data_loader.dataset)
    delta = 0.05
    bound = math.sqrt((final_kl + math.log(2*math.sqrt(N)/delta)) / (2*N))
    print(f"PAC-Bayesian bound: {bound:.4e}")
    return model

