D.1 Forward Kinematics via POE (Detailed Implementation)

```python
import numpy as np
from scipy.linalg import expm

def vec_to_skew(v):
    """Convert 3-vector to skew-symmetric matrix."""
    return np.array([[0, -v[2], v[1]],
                     [v[2], 0, -v[0]],
                     [-v[1], v[0], 0]])

def twist_to_matrix(twist):
    """Convert twist (v, omega) to 4x4 matrix representation."""
    v = twist[:3]
    omega = twist[3:]
    w_skew = vec_to_skew(omega)
    matrix = np.zeros((4,4))
    matrix[:3,:3] = w_skew
    matrix[:3,3] = v
    return matrix

def exp_twist(twist, theta):
    """Compute exponential of twist * theta."""
    v = twist[:3]
    omega = twist[3:]
    w_norm = np.linalg.norm(omega)
    if w_norm < 1e-10:
        # Pure translation
        R = np.eye(3)
        p = v * theta
    else:
        w_skew = vec_to_skew(omega / w_norm)
        R = np.eye(3) + np.sin(w_norm*theta) * w_skew + \
            (1 - np.cos(w_norm*theta)) * w_skew @ w_skew
        p = (np.eye(3) - R) @ np.cross(omega/w_norm, v) + \
            (omega @ v) * omega / w_norm**2 * theta
    T = np.eye(4)
    T[:3,:3] = R
    T[:3,3] = p
    return T

def poe_fk(screw_axes, theta, M):
    """
    screw_axes: list of 6-vectors (in base frame)
    theta: joint angles
    M: home configuration (4x4)
    """
    T = M.copy()
    for i in range(len(theta)-1, -1, -1):
        T = exp_twist(screw_axes[i], theta[i]) @ T
    return T
```

D.2 Port-Hamiltonian Simulation (RK4 with Symplectic Integration)

```python
def port_hamiltonian_rhs(t, x, params):
    q = x[:params.n]
    p = x[params.n:2*params.n]
    ell = x[2*params.n:]
    
    # Hamiltonian and derivatives
    M_inv = np.linalg.inv(params.M(q))
    H = 0.5 * p @ M_inv @ p + params.V(q) + 0.5 * ell @ params.K_e @ ell
    
    dH_dq = params.grad_V(q) + 0.5 * p @ params.dM_inv(q) @ p
    dH_dp = M_inv @ p
    dH_dell = params.K_e @ ell
    
    # Structure matrices
    J = np.block([[np.zeros((params.n,params.n)), np.eye(params.n), np.zeros((params.n,params.m))],
                  [-np.eye(params.n), np.zeros((params.n,params.n)), np.zeros((params.n,params.m))],
                  [np.zeros((params.m,params.n)), np.zeros((params.m,params.n)), np.zeros((params.m,params.m))]])
    R = np.block([[np.zeros((params.n,params.n)), np.zeros((params.n,params.n)), np.zeros((params.n,params.m))],
                  [np.zeros((params.n,params.n)), params.D(q, p), np.zeros((params.n,params.m))],
                  [np.zeros((params.m,params.n)), np.zeros((params.m,params.n)), params.R_tendon(ell)]])
    
    # Input matrix
    B = np.vstack([np.zeros((params.n, params.m)),
                   params.P(q).T,
                   np.zeros((params.m, params.m))])
    
    u = params.control(t, q, p, ell)
    
    dx = (J - R) @ np.concatenate([dH_dq, dH_dp, dH_dell]) + B @ u
    return dx

def symplectic_rk4_step(x, t, dt, params):
    k1 = port_hamiltonian_rhs(t, x, params)
    k2 = port_hamiltonian_rhs(t + dt/2, x + dt/2 * k1, params)
    k3 = port_hamiltonian_rhs(t + dt/2, x + dt/2 * k2, params)
    k4 = port_hamiltonian_rhs(t + dt, x + dt * k3, params)
    return x + dt/6 * (k1 + 2*k2 + 2*k3 + k4)
```

D.3 Pattern Classification with Distance Weighting

```python
def classify_grasp(theta, pattern_library, W, eps=0.1):
    """
    theta: joint angle vector
    pattern_library: list of Pattern objects with fields:
        - theta_min, theta_max: arrays
        - nominal: array (representative configuration)
        - object: object parameters for force closure check
        - importance_weights: array for W (optional)
    W: diagonal weight matrix (or vector)
    """
    best_pattern = None
    min_dist = np.inf
    for p in pattern_library:
        # Check joint limits
        if np.any(theta < p.theta_min) or np.any(theta > p.theta_max):
            continue
        # Check force closure (simplified)
        if not force_closure(theta, p.object):
            continue
        # Compute weighted distance
        diff = theta - p.nominal
        if W.ndim == 1:
            dist = np.sqrt(np.sum(W * diff**2))
        else:
            dist = np.sqrt(diff @ W @ diff)
        if dist < min_dist:
            min_dist = dist
            best_pattern = p
    if min_dist < eps:
        return best_pattern, min_dist
    else:
        return None, min_dist
