    def __init__(self, hydrogen_period_ns=0.704, ppm_slots=256):
        self.T_H = hydrogen_period_ns  # ns
        self.slot_multiplier = 10      # 2^10 = 1024
        self.slot_duration_ns = (2**self.slot_multiplier) * self.T_H
        self.M = ppm_slots             # PPM order
        self.handshake_bits = None
        self.interleaver_seed = None

    def generate_primes(self, n):
        """Generate first n prime numbers using simple sieve."""
        primes = []
        num = 2
        while len(primes) < n:
            is_prime = True
            for p in primes:
                if p * p > num:
                    break
                if num % p == 0:
                    is_prime = False
                    break
            if is_prime:
                primes.append(num)
            num += 1
        return primes

    def handshake_sequence(self, n=28):
        """
        Return self-delimiting binary representation using unary exponents.
        For n=28, this yields the required Kt gap > 2000 bits (proved in Thm A.1).
        """
        primes = self.generate_primes(n)
        bits = []
        for p in primes:
            # p times '1', then '0', then p times '1'
            bits.extend([1] * p)
            bits.append(0)
            bits.extend([1] * p)
        self.handshake_bits = bits
        # Seed from first 32 bits of handshake
        seed_bits = bits[:32]
        seed_int = 0
        for b in seed_bits:
            seed_int = (seed_int << 1) | b
        self.interleaver_seed = seed_int % (2**32)
        return bits

    def interleaver(self, bit_stream):
        """Deterministic interleaving using handshake-derived seed."""
        arr = np.array(bit_stream)
        rng = np.random.default_rng(self.interleaver_seed)
        perm = rng.permutation(len(arr))
        interleaved = arr[perm]
        self.deinterleave_perm = np.argsort(perm)
        return interleaved.tolist()

    def deinterleaver(self, interleaved_stream):
        """Reverse the interleaving."""
        arr = np.array(interleaved_stream)
        return arr[self.deinterleave_perm].tolist()

    def reed_solomon_encode(self, data_symbols):
        """Placeholder: actual RS(255,223) over GF(256) would go here."""
        return data_symbols + [0]*32

    def encode_full_capsule(self, payload_bits):
        """Complete encoding pipeline."""
        handshake = self.handshake_sequence(n=28)  # n=28 satisfies Theorem A.1
        rs_encoded = self.reed_solomon_encode(payload_bits)
        interleaved = self.interleaver(rs_encoded)
        return {
            "handshake": handshake,
            "slot_duration_ns": self.slot_duration_ns,
            "interleaver_seed": self.interleaver_seed,
            "interleaved_bits": interleaved
        }

