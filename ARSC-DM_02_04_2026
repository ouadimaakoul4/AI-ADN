def observability_gramian(A_list, H_list, R_inv, N):
    """
    Compute finite-horizon observability Gramian.
    A_list: list of linearized dynamics matrices (size n x n) for k=0..N-1
    H_list: list of measurement Jacobians (size p x n)
    R_inv: inverse measurement noise covariance
    """
    n = A_list[0].shape[0]
    O = torch.zeros(n, n)
    Phi = torch.eye(n)
    for k in range(N):
        O = O + Phi.T @ H_list[k].T @ R_inv @ H_list[k] @ Phi
        Phi = A_list[k] @ Phi
    return O

def incremental_iss_bound(e0, w_sup, O_min_eig, beta0=1.0, gamma_gain=1.0):
    """
    Compute ISS bound: ||e_k|| <= beta0 * exp(-lambda * k) * ||e0|| + gamma_gain * w_sup
    """
    lambda_ = O_min_eig  # decay rate from observability
    beta = beta0 * torch.exp(-lambda_ * torch.arange(len(e0)))
    return beta * torch.norm(e0) + gamma_gain * w_sup

