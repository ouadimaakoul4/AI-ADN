```python
# slow_loop.py - Runs at 50 Hz on separate thread/process

import torch
import numpy as np
from collections import deque

class SlowAdaptationLoop:
    def __init__(self, config):
        # Networks
        self.theta_hat = torch.zeros(config.dim_theta, requires_grad=True)
        self.residual_policy = ResidualMLP(config)
        self.force_predictor = ForcePredictorMLP(config)
        self.nominal_policy = load_nominal_policy(config.ckpt_path)
        
        # Buffer
        self.buffer = deque(maxlen=config.buffer_size)
        
        # Optimizer
        self.optimizer = torch.optim.Adam([
            {'params': self.theta_hat, 'lr': config.lr_theta},
            {'params': self.residual_policy.parameters(), 'lr': config.lr_phi}
        ])
        self.scheduler = torch.optim.lr_scheduler.LambdaLR(
            self.optimizer, lr_lambda=lambda step: config.lr_0 / np.sqrt(step + 1)
        )
        
        self.step_count = 0
        
    def update(self, new_data: dict):
        """Called at 50 Hz with latest sensor tuple."""
        # Add to buffer
        self.buffer.append(new_data)
        
        if len(self.buffer) < BATCH_SIZE:
            return
            
        # Sample batch
        batch = random.sample(self.buffer, BATCH_SIZE)
        z_batch, a_batch, f_batch = collate(batch)
        
        # 1. Update theta_hat via force prediction
        f_pred = self.force_predictor(z_batch, a_batch, self.theta_hat)
        loss_theta = torch.nn.functional.mse_loss(f_pred, f_batch)
        
        # 2. Residual policy loss (minimize CLF violation)
        V_dot_actual = estimate_V_dot_from_data(batch)
        loss_res = torch.relu(V_dot_actual + alpha * V - delta_thresh).mean()
        
        # 3. Combined loss
        total_loss = loss_theta + lambda_res * loss_res
        
        self.optimizer.zero_grad()
        total_loss.backward()
        torch.nn.utils.clip_grad_norm_(self.residual_policy.parameters(), max_norm=G)
        self.optimizer.step()
        self.scheduler.step()
        
        self.step_count += 1
        
        # 4. Periodic meta-update of nominal policy (rare)
        if self.step_count % META_INTERVAL == 0:
            self.meta_update_nominal()
            
    def meta_update_nominal(self):
        """MAML inner-loop update on recent data."""
        # Create copy of nominal policy
        theta_prime = self.nominal_policy.state_dict().copy()
        
        # Inner loop: one gradient step on task-specific loss
        task_loss = compute_task_loss(self.buffer)
        grad = torch.autograd.grad(task_loss, self.nominal_policy.parameters())
        for name, param in theta_prime.items():
            theta_prime[name] = param - alpha_inner * grad[name]
            
        # Outer loop: update original params toward adapted version
        for name, param in self.nominal_policy.named_parameters():
            param.data = param.data - lr_outer * (param.data - theta_prime[name])
