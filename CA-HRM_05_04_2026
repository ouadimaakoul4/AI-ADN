import torch
import torch.nn as nn
import torch.autograd.functional as F

class LiftedHierarchicalTransition(nn.Module):
    def __init__(self, d_z, d_m, d_input, hidden_sizes, k_H=0.5, k_L=0.99):
        super().__init__()
        # High-level (contractive)
        self.f_H = nn.Sequential(
            nn.utils.spectral_norm(nn.Linear(d_z + d_m, hidden_sizes[0])),
            nn.Tanh(),
            nn.utils.spectral_norm(nn.Linear(hidden_sizes[0], d_z // 2))
        )
        # Low-level (near-unitary)
        self.f_L = nn.Sequential(
            nn.Linear(d_z // 2 + d_z // 2 + d_input, hidden_sizes[1]),
            nn.Tanh(),
            nn.Linear(hidden_sizes[1], d_z // 2)
        )
        # Memory GRU with spectral norm
        self.gru = nn.GRUCell(d_z, d_m)
        for name, param in self.gru.named_parameters():
            if 'weight' in name:
                nn.utils.spectral_norm(self.gru, name=name)
        
        # Store desired contraction bounds for regularization
        self.k_H = k_H
        self.k_L = k_L
    
    def forward(self, z, m, x, gamma=1.0):
        # Split latent
        z_H, z_L = z.chunk(2, dim=-1)
        # High-level update (contractive)
        z_H_next = self.f_H(torch.cat([z_H, m], dim=-1))
        # Low-level update (expressive)
        z_L_next = self.f_L(torch.cat([z_L, z_H_next, x], dim=-1))
        z_next = torch.cat([z_H_next, z_L_next], dim=-1)
        # Memory update
        m_next = self.gru(z, m)   # No detach – keep graph for implicit diff
        # Apply step size
        z = z + gamma * (z_next - z)
        m = m + gamma * (m_next - m)
        return z, m

class CAHRM(nn.Module):
    def __init__(self, d_z, d_m, d_input, K=3, max_steps=20, eps=1e-4, sigma=0.01):
        super().__init__()
        self.transition = LiftedHierarchicalTransition(d_z, d_m, d_input, hidden_sizes=[128,128])
        self.fast_proj = nn.Linear(d_input, d_z + d_m)  # warm-start
        self.halt_head = nn.Linear(d_z + d_m, 1)
        self.critic = nn.Sequential(
            nn.Linear(d_z + d_m + d_input, 64),
            nn.ReLU(),
            nn.Linear(64, 1),
            nn.Sigmoid()
        )
        self.K = K
        self.max_steps = max_steps
        self.eps = eps
        self.sigma = sigma
    
    def energy(self, s, s_next):
        return 0.5 * (s_next - s).pow(2).sum(dim=-1).mean()
    
    def adaptive_gamma(self, energy):
        # gamma in (0, 0.5], high energy -> large gamma
        return torch.sigmoid(-2.0 * energy) * 0.5
    
    def forward(self, x, y=None, train=True):
        batch_size = x.size(0)
        device = x.device
        
        # Warm-start base
        s_base = self.fast_proj(x)  # (batch, d_z+d_m)
        # Generate K perturbed initial states
        s0_list = [s_base + self.sigma * torch.randn_like(s_base) for _ in range(self.K)]
        
        best_s = None
        best_energy = float('inf')
        halt_steps = []
        
        for k in range(self.K):
            s = s0_list[k]
            z, m = s[:, :d_z], s[:, d_z:]
            steps = 0
            for t in range(self.max_steps):
                z_next, m_next = self.transition(z, m, x)
                s_next = torch.cat([z_next, m_next], dim=-1)
                energy_val = self.energy(torch.cat([z,m], dim=-1), s_next)
                gamma = self.adaptive_gamma(energy_val)
                # Apply step size
                z = z + gamma * (z_next - z)
                m = m + gamma * (m_next - m)
                s = torch.cat([z, m], dim=-1)
                
                # Halting condition
                p_halt = torch.sigmoid(self.halt_head(s)).squeeze(-1)
                if (energy_val < self.eps).any() or (p_halt > 0.95).any():
                    halt_steps.append(t+1)
                    break
                steps += 1
            else:
                halt_steps.append(self.max_steps)
            
            if energy_val < best_energy:
                best_energy = energy_val
                best_s = s
        
        s_star = best_s
        if train and y is not None:
            return s_star, best_energy, halt_steps
        return s_star

# Implicit differentiation with exact VJP
def implicit_gradient(loss, s_star, transition, x, n_iter=10):
    # Compute gradient w.r.t. s_star
    grad_s = torch.autograd.grad(loss, s_star, retain_graph=True)[0]
    
    def vjp_fn(v):
        # Compute J^T v using VJP
        def g_fn(s):
            z, m = s.chunk(2, dim=-1)
            z_next, m_next = transition(z, m, x)
            return torch.cat([z_next, m_next], dim=-1)
        _, vjp = F.vjp(g_fn, s_star, v)
        return vjp
    
    # Neumann solve for (I - J)^-T grad_s
    v = grad_s.clone()
    for _ in range(n_iter):
        v = grad_s + vjp_fn(v)[0]   # v = g + J^T v
    
    # Now v = (I - J)^-T grad_s
    # Compute gradients w.r.t. transition parameters using standard autograd
    # (For simplicity, we assume the loss already depends on s_star, and we replace the gradient)
    return v

# Training loop with custom implicit step
def train_step(model, optimizer, x, y):
    optimizer.zero_grad()
    s_star, energy, steps = model(x, y, train=True)
    
    # Task loss (e.g., classification head)
    logits = nn.Linear(s_star.size(-1), num_classes).to(s_star.device)(s_star)
    loss_task = nn.CrossEntropyLoss()(logits, y)
    
    loss_halt = 0.05 * sum(steps) / len(steps)
    
    # Monotonicity regularizer (estimate min eigenvalue of J_F)
    def F_fn(s):
        z, m = s.chunk(2, dim=-1)
        z_next, m_next = model.transition(z, m, x)
        return s - torch.cat([z_next, m_next], dim=-1)
    J_F = torch.autograd.functional.jacobian(F_fn, s_star, vectorize=True)
    min_eig = torch.linalg.eigvalsh(J_F + J_F.transpose(-2,-1)).min()
    loss_mono = torch.relu(0.1 - min_eig)  # encourage strong monotonicity
    
    loss_crit = 0.5 * (model.critic(torch.cat([s_star, x.expand_as(s_star)], dim=-1)) - 1.0).pow(2).mean()
    
    loss = loss_task + 0.1 * energy + loss_halt + 0.5 * loss_mono + 0.2 * loss_crit
    
    # Replace gradient of s_star with implicit gradient
    grad_s = torch.autograd.grad(loss, s_star, create_graph=True)[0]
    implicit_grad = implicit_gradient(loss, s_star, model.transition, x)
    # Manually set gradients for parameters (simplified; in practice use hooks)
    for param in model.parameters():
        param.grad = None
    # This is a sketch – full implementation would require a custom autograd.Function
