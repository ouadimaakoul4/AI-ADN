            nn.ReLU(),
            nn.Conv1d(32, 32, kernel_size=5),
            nn.ReLU(),
            nn.AdaptiveAvgPool1d(seq_len//4)
        )
        self.lstm = nn.LSTM(32, hidden_dim, num_layers=2, batch_first=True)
        self.fc = nn.Linear(hidden_dim, 12)

    def forward(self, x):
        # x shape: (batch, seq_len, input_dim)
        x = x.transpose(1,2)  # (batch, input_dim, seq_len)
        x = self.cnn(x)        # (batch, 32, seq_len')
        x = x.transpose(1,2)  # (batch, seq_len', 32)
        _, (h_n, _) = self.lstm(x)
        return self.fc(h_n[-1])  # (batch, 12)

class IKNSProjection:
    def __init__(self, coupling_jacobian_function):
        self.Jc = coupling_jacobian_function  # returns 6×m matrix

    def project(self, q_dot_des, q_human):
        J = self.Jc(q_human)
        J_pinv = np.linalg.pinv(J)
        P = np.eye(J.shape[1]) - J_pinv @ J
        return P @ q_dot_des

class PIDController:
    def __init__(self, Kp, Ki, Kd, dt=0.02):
        self.Kp = Kp
        self.Ki = Ki
        self.Kd = Kd
        self.dt = dt
        self.integral = np.zeros(12)

    def compute(self, q_des, q, q_dot_des, q_dot):
        e = q_des - q
        e_dot = q_dot_des - q_dot
        self.integral += e * self.dt
        tau = self.Kp @ e + self.Kd @ e_dot + self.Ki @ self.integral
        return tau

class SharedAutonomy:
    def __init__(self, kappa=5.0, C_th=50.0):
        self.kappa = kappa
        self.C_th = C_th

    def blend(self, u_hat, u_auto, cognitive_load):
        rho = 1.0 / (1.0 + np.exp(self.kappa * (cognitive_load - self.C_th)))
        return rho * u_hat + (1 - rho) * u_auto

class MainLoop:
    def __init__(self):
        self.eeg = EEGAcquisition()
        self.preproc = Preprocessing()
        self.rf = RiemannianFeatures(64, precomputed_ref())
        self.decoder = CNNLSTMDecoder()
        self.ikns = IKNSProjection(coupling_jacobian)
        self.pid = PIDController(Kp=diag([100]*12), Ki=diag([10]*12), Kd=diag([50]*12))
        self.sa = SharedAutonomy()

    def run(self):
        while True:
            # Stage 1‑2
            raw = self.eeg.acquire()
            cleaned = self.preproc.process(raw)
            # Stage 3‑4 (every 250 ms)
            if new_window_ready():
                cov = self.rf.compute_covariance(cleaned)
                X = self.rf.tangent_projection(cov)
                u_hat = self.decoder.forward(X)  # 12‑dim intent
            # Stage 5 (every 20 ms)
            u_auto = autonomous_policy(q_r, q_h)
            cognitive_load = estimate_load(pupil, hrv)
            u_final = self.sa.blend(u_hat, u_auto, cognitive_load)
            q_dot_des = self.ikns.project(u_final, q_h)
            q_des = integrate(q_dot_des, dt=0.02)
            tau = self.pid.compute(q_des, q_r, q_dot_des, q_dot_r)
            send_torque(tau)
            # Stage 6 (feedback)
            tactile = compute_tactile(force_sensors)
            render_vibrotactile(tactile)
