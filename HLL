            self.gear_height = 3.5  # m
        else:
            raise ValueError(f"Unknown vehicle: {vehicle}")
        
        # Model parameters (from Langley 2026)
        self.k = 0.35  # scaling factor
        self.a = 0.45  # thrust exponent
        self.b = 0.6   # time exponent
        self.p_ref = 1e4  # Pa
        self.t_ref = 1.0  # s
        
        # Soil properties
        self.p_strength_mean = 1e4  # Pa
        self.p_strength_std = 0.5e4  # Pa
        
        # Ejecta model
        self.v_max = 25.0  # m/s
        self.r_plume = 10.0  # m
        self.r0 = 1.0  # m
    
    def compute_crater_depth(self, T, t_burn, p_strength=None, p_e=5000):
        """
        Compute crater depth
        
        Parameters:
            T: thrust (N)
            t_burn: burn time at this altitude (s)
            p_strength: soil bearing strength (Pa) - if None, use mean
            p_e: nozzle exit pressure (Pa)
        
        Returns:
            h_crater: crater depth (m)
        """
        if p_strength is None:
            p_strength = self.p_strength_mean
        
        # Normalized thrust term
        thrust_term = (T / self.A_ref) / p_strength
        
        # Time term
        time_term = t_burn / self.t_ref
        
        # Pressure term
        pressure_term = 1 + p_e / self.p_ref
        
        # Crater depth
        h_crater = self.k * (thrust_term ** self.a) * (time_term ** self.b) * pressure_term
        
        return h_crater
    
    def compute_ejecta_velocity(self, r):
        """
        Compute ejecta velocity at distance r from plume center
        
        Parameters:
            r: distance from plume center (m)
        
        Returns:
            v: ejecta velocity (m/s)
        """
        if r < self.r0:
            return self.v_max
        else:
            return self.v_max * (r / self.r0) ** (-1.5) * np.exp(-r / self.r_plume)
    
    def check_failure(self, h_crater, ejecta_flux, altitude):
        """
        Check for PSI-induced failures
        
        Returns:
            failure_type: None or string indicating failure mode
        """
        # Crater depth failure
        if h_crater > self.gear_height + 0.5:  # 0.5 m margin
            return 'crater_exceeds_gear'
        
        # Ejecta damage failure
        if ejecta_flux > 1.0:  # kg/m²/s, critical threshold
            return 'ejecta_damage'
        
        # Obscuration (simplified - based on dust density)
        dust_density = ejecta_flux / 10.0  # rough estimate
        if dust_density > 0.1 and altitude < 50:  # kg/m³, critical near surface
            return 'sensor_obscuration'
        
        return None
    
    def update(self, T, altitude, dt, cumulative_time, p_strength=None):
        """
        Update PSI state
        
        Returns:
            h_crater: current crater depth
            failure: failure type or None
        """
        # Only significant when close to surface
        if altitude > 500:
            return 0.0, None
        
        # Increment burn time at this altitude
        self.burn_time_below_500 += dt
        
        # Compute current crater depth
        h_crater = self.compute_crater_depth(T, self.burn_time_below_500, p_strength)
        
        # Compute ejecta flux at vehicle location (simplified)
        # Assume vehicle at center of plume
        r_vehicle = 0.0  # directly under nozzle
        v_ejecta = self.compute_ejecta_velocity(r_vehicle + 1.0)  # offset for numerical stability
        ejecta_flux = 0.1 * v_ejecta  # rough scaling
        
        # Check for failure
        failure = self.check_failure(h_crater, ejecta_flux, altitude)
        
        return h_crater, failure
