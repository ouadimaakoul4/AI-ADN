```python
import shap

def explain_with_shap(model, X_background, X_explain, mask_background, mask_explain):
    """
    Compute SHAP values for model predictions.
    
    Args:
        model: PyTorch model
        X_background: background dataset for KernelSHAP (e.g., 100 random cycles)
        X_explain: instances to explain
        mask_background, mask_explain: corresponding masks
    Returns:
        shap_values: list of SHAP value arrays for each feature
    """
    # Convert model to a function that takes numpy array and returns predictions
    def model_predict(x):
        # x is expected to be of shape (n_samples, seq_len, input_dim)
        model.eval()
        with torch.no_grad():
            x_torch = torch.tensor(x, dtype=torch.float32)
            # Assume mask is None or we need to create appropriate mask
            # For simplicity, we assume no padding in these examples
            pred = model(x_torch, None).cpu().numpy()
        return pred
    
    # Use KernelSHAP (or DeepSHAP for deep models)
    explainer = shap.KernelExplainer(model_predict, X_background.reshape(X_background.shape[0], -1))
    shap_values = explainer.shap_values(X_explain.reshape(X_explain.shape[0], -1))
    return shap_values
