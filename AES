  le c1 c2 := match c1, c2 with
    | .none, _           => true
    | .bronze, .bronze   => true
    | .bronze, .silver   => true
    | .bronze, .gold     => true
    | .silver, .silver   => true
    | .silver, .gold     => true
    | .gold, .gold       => true
    | _, _               => false
  le_refl := by intro c; cases c <;> simp
