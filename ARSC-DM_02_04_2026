import torch
import gpytorch
from gpytorch.kernels import MaternKernel, ScaleKernel
from gpytorch.means import ConstantMean
from gpytorch.likelihoods import GaussianLikelihood
from gpytorch.mlls import VariationalELBO
from gpytorch.variational import VariationalStrategy, CholeskyVariationalDistribution

class MultiFidelityGP(gpytorch.models.ApproximateGP):
    """
    Autoregressive multi-fidelity GP with sparse variational approximation.
    Implements: f_h(x) = rho(x) * f_l(x) + delta(x)
    """
    def __init__(self, inducing_points, low_fidelity_model=None):
        variational_distribution = CholeskyVariationalDistribution(inducing_points.size(0))
        variational_strategy = VariationalStrategy(self, inducing_points, variational_distribution)
        super().__init__(variational_strategy)
        
        self.low_fidelity_model = low_fidelity_model
        self.mean_module = ConstantMean()
        self.covar_module = ScaleKernel(MaternKernel(nu=2.5, ard_num_dims=3))
        self.likelihood = GaussianLikelihood()
        
    def forward(self, x):
        mean = self.mean_module(x)
        covar = self.covar_module(x)
        return gpytorch.distributions.MultivariateNormal(mean, covar)
    
    def predict(self, x_low, x_high, y_low, y_high, inducing_points, lr=0.01, iterations=500):
        """Train the variational GP using ELBO."""
        self.set_train_data(x_low, y_low, strict=False)
        optimizer = torch.optim.Adam(self.parameters(), lr=lr)
        mll = VariationalELBO(self.likelihood, self, num_data=len(y_high))
        
        for i in range(iterations):
            optimizer.zero_grad()
            output = self(x_high)
            loss = -mll(output, y_high)
            loss.backward()
            optimizer.step()
            if i % 100 == 0:
                print(f"ELBO: {-loss.item():.4f}")
        return self

