```python
class NCEAdaptiveController:
    def __init__(self, I_nominal, lambda_gain=2.0, KD=100.0, Gamma=0.1, sigma=0.01):
        """
        Non-Certainty Equivalence Adaptive Controller
        
        Parameters:
            I_nominal: nominal inertia tensor (3x3)
            lambda_gain: sliding surface gain
            KD: derivative gain
            Gamma: adaptation gain
            sigma: leakage (sigma-modification) gain
        """
        self.I_hat = I_nominal.copy()
        self.I_hat_inv = np.linalg.inv(self.I_hat)
        self.lambda_gain = lambda_gain
        self.KD = KD
        self.Gamma = Gamma
        self.sigma = sigma
        
        # Parameter vector [Ixx, Iyy, Izz, Ixy, Ixz, Iyz]
        self.theta_hat = self.inertia_to_parameters(self.I_hat)
        self.n_params = 6
    
    def inertia_to_parameters(self, I):
        """Convert inertia tensor to parameter vector"""
        return np.array([I[0,0], I[1,1], I[2,2], I[0,1], I[0,2], I[1,2]])
    
    def parameters_to_inertia(self, theta):
        """Convert parameter vector to inertia tensor"""
        I = np.zeros((3,3))
        I[0,0] = theta[0]
        I[1,1] = theta[1]
        I[2,2] = theta[2]
        I[0,1] = I[1,0] = theta[3]
        I[0,2] = I[2,0] = theta[4]
        I[1,2] = I[2,1] = theta[5]
        return I
    
    def compute_regressor(self, omega, omega_d, omega_d_dot, e_dot):
        """
        Compute regressor matrix Y for attitude dynamics
        
        Dynamics: I ω_dot + ω × I ω = Y θ
        """
        # For simplicity, use linearized regressor
        Y = np.zeros((3, 6))
        
        # Terms from I ω_dot_d
        Y[0, 0] = omega_d_dot[0]  # Ixx term
        Y[1, 1] = omega_d_dot[1]  # Iyy term
        Y[2, 2] = omega_d_dot[2]  # Izz term
        
        # Terms from ω × I ω (simplified)
        Y[0, 1] = -omega[1]*omega[2]  # from Iyy
        Y[0, 2] = omega[1]*omega[2]   # from Izz
        Y[1, 0] = omega[0]*omega[2]   # from Ixx
        Y[1, 2] = -omega[0]*omega[2]  # from Izz
        Y[2, 0] = -omega[0]*omega[1]  # from Ixx
        Y[2, 1] = omega[0]*omega[1]   # from Iyy
        
        # Off-diagonal terms (simplified - full expression is more complex)
        # This is a placeholder; full regressor would include all products
        
        return Y
    
    def compute_control(self, omega, omega_d, omega_d_dot, e, e_dot, dt):
        """
        Compute control torque
        
        Returns:
            tau: control torque (3x1)
            theta_hat_updated: updated parameter estimates
        """
        # Sliding surface
        s = e_dot + self.lambda_gain * e
        
        # Regressor
        Y = self.compute_regressor(omega, omega_d, omega_d_dot, e_dot)
        
        # Parameter error (using current estimate - true unknown)
        # In simulation, we have access to true parameters for error computation
        # For actual flight, this term would be zero
        if hasattr(self, 'theta_true'):
            theta_tilde = self.theta_hat - self.theta_true
        else:
            theta_tilde = np.zeros(self.n_params)
        
        # Nominal control (based on estimated inertia)
        I_hat = self.parameters_to_inertia(self.theta_hat)
        tau_nom = I_hat @ (omega_d_dot - self.lambda_gain * e_dot) + np.cross(omega, I_hat @ omega)
        
        # Adaptive term
        tau_adapt = Y @ theta_tilde
        
        # Sliding term
        tau_slide = -self.KD * s
        
        # Total control
        tau = tau_nom + tau_slide - tau_adapt
        
        # Parameter update
        theta_hat_dot = -self.Gamma * Y.T @ s - self.Gamma * self.sigma * self.theta_hat
        self.theta_hat += theta_hat_dot * dt
        
        # Ensure symmetry and positive definiteness
        I_updated = self.parameters_to_inertia(self.theta_hat)
        # Project to ensure positive definite (simplified)
        self.theta_hat = self.inertia_to_parameters(I_updated)
        
        return tau, self.theta_hat
