12:        z_t ← GRU_ψ(s_{t-k:t})
13:        s_t_aug ← [s_t; z_t]
14:        
15:        // Select action
16:        a_t ∼ π_θ(· | s_t_aug)
17:        
18:        // Step GNS surrogate
19:        s_{t+1}, r_t ← GNS.step(a_t, c, φ)
20:        
21:        // Store transition
22:        D.append(s_t, a_t, r_t, s_{t+1})
23:    end for
24:    
25:    // Compute advantages
26:    for t = T down to 1 do
27:        δ_t ← r_t + γ V(s_{t+1}) - V(s_t)
28:        A_t ← Σ_{l=0} (γλ)^l δ_{t+l}
29:        R_t ← A_t + V(s_t)
30:    end for
31:    
32:    // PPO update (K epochs)
33:    for epoch = 1 to K do
34:        for minibatch in D do
35:            r(θ) ← π_θ(a|s) / π_θ_old(a|s)
36:            L_CLIP ← min(r(θ)A, clip(r(θ), 1-ε, 1+ε)A)
37:            L_VF ← (V_φ(s) - R)²
38:            L_total ← -L_CLIP + c₁ L_VF - c₂ H[π_θ]
39:            
40:            θ ← θ - α ∇_θ L_total
41:            φ ← φ - α ∇_φ L_VF
42:        end for
43:    end for
44:    
45:    // Update environment encoder
46:    ψ ← ψ - α_enc ∇_ψ L_total
47:    
48:    θ_old ← θ
49: end for
50: return π_θ, V_φ, GRU_ψ
