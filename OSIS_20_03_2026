C.3 Symplectic Mediator Implementation

```python
class SymplecticHamiltonianMediator:
    def __init__(self, components, coupling_gamma, dt):
        self.components = components
        self.gamma = coupling_gamma
        self.dt = dt
        self.q = {comp.id: comp.state.q for comp in components}
        self.p = {comp.id: comp.state.p for comp in components}

    def step(self):
        # Symplectic Euler: update p first using current q, then q using new p
        for i in self.components:
            dH_dq_i = self.compute_gradient_q(i, self.q, self.p)
            self.p[i] = self.p[i] - self.dt * dH_dq_i

        for i in self.components:
            dH_dp_i = self.compute_gradient_p(i, self.p)
            self.q[i] = self.q[i] + self.dt * dH_dp_i

        # Broadcast updated q, p to components
        for comp in self.components:
            comp.receive_coupling(self.q[comp.id], self.p[comp.id])

    def compute_gradient_q(self, i, q, p):
        # ∂H/∂q_i = ∂U_i/∂q_i + γ Σ_{j≠i} ∂Φ_ij/∂q_i
        grad = self.components[i].local_potential_gradient(q[i])
        for j in self.components:
            if j != i:
                grad += self.gamma * self.coupling_potential_gradient(q[i], q[j], i)
        return grad

    def compute_gradient_p(self, i, p):
        # ∂H/∂p_i = p_i (kinetic energy T(p) = (1/2)‖p‖²)
        return p[i]
```

