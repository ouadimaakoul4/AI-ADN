D.5 Mediation Analysis with Bootstrapping

```python
from sklearn.utils import resample
import statsmodels.api as sm

def parallel_mediation(X, mediators, Y, n_bootstrap=5000):
    # X: array of condition (0/1)
    # mediators: dict of mediator_name -> array
    # Y: outcome array
    # Returns: indirect effects with bootstrap CI
    n = len(X)
    # Fit mediator models
    mediator_coefs = {}
    for name, M in mediators.items():
        model = sm.OLS(M, sm.add_constant(X)).fit()
        mediator_coefs[name] = model.params[1]  # a coefficient

    # Fit outcome model
    all_vars = np.column_stack([X] + list(mediators.values()))
    outcome_model = sm.OLS(Y, sm.add_constant(all_vars)).fit()
    # b coefficients for each mediator (from outcome model)
    b_coefs = outcome_model.params[2:2+len(mediators)]

    # Bootstrap
    indirect_effects = {name: [] for name in mediators}
    for _ in range(n_bootstrap):
        idx = resample(range(n))
        X_b = X[idx]
        Y_b = Y[idx]
        mediators_b = {name: M[idx] for name, M in mediators.items()}
        # Recompute a coefficients
        a_b = {}
        for name, M in mediators_b.items():
            mod = sm.OLS(M, sm.add_constant(X_b)).fit()
            a_b[name] = mod.params[1]
        # Recompute b coefficients
        all_vars_b = np.column_stack([X_b] + list(mediators_b.values()))
        mod_out = sm.OLS(Y_b, sm.add_constant(all_vars_b)).fit()
        b_b = mod_out.params[2:2+len(mediators)]
        for i, name in enumerate(mediators):
            indirect_effects[name].append(a_b[name] * b_b[i])

    # Compute 95% CI
    cis = {}
    for name in mediators:
        ci = np.percentile(indirect_effects[name], [2.5, 97.5])
        cis[name] = ci
    return cis
