\mathbf{S}(t) = \bigl( \tilde{\mathcal{M}}_s, \tilde{\mathcal{M}}_e, \tilde{\mathcal{M}}_i, \tilde{\mathcal{M}}_d, A, R, [\text{GFAP}], \mathcal{D}_c \bigr)

