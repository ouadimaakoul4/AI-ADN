6.A.1 SOCP Guidance Solver

```python
def solve_socp_guidance(r0, v0, m0, r_target, N=50):
    """
    Solve fuel-optimal powered descent guidance using SOCP
    
    Parameters:
        r0, v0: initial position and velocity (3x1)
        m0: initial mass
        r_target: target landing position (3x1)
        N: number of discretization nodes
    
    Returns:
        T_opt: optimal thrust vectors (Nx3)
        r_opt: optimal trajectory (Nx3)
        v_opt: optimal velocity profile (Nx3)
    """
    import cvxpy as cp
    import numpy as np
    
    # Time discretization
    dt = 1.0  # seconds, will be adapted
    
    # Variables
    T = cp.Variable((N, 3))  # thrust at each node
    r = cp.Variable((N, 3))  # position
    v = cp.Variable((N, 3))  # velocity
    m = cp.Variable(N)       # mass
    gamma = cp.Variable(N)   # slack for thrust magnitude
    
    # Objective: minimize total fuel (integral of thrust magnitude)
    objective = cp.Minimize(cp.sum(gamma) * dt)
    
    # Constraints
    constraints = []
    
    # Initial conditions
    constraints += [r[0, :] == r0]
    constraints += [v[0, :] == v0]
    constraints += [m[0] == m0]
    
    # Dynamics (Euler integration)
    for k in range(N-1):
        constraints += [r[k+1, :] == r[k, :] + v[k, :] * dt + 
                        0.5 * (T[k, :] / m[k] + g_m) * dt**2]
        constraints += [v[k+1, :] == v[k, :] + (T[k, :] / m[k] + g_m) * dt]
        constraints += [m[k+1] == m[k] - cp.norm(T[k, :]) / (g0 * Isp) * dt]
    
    # Terminal constraints
    constraints += [r[N-1, :] == r_target]
    constraints += [v[N-1, :] == 0]
    
    # Thrust constraints
    for k in range(N):
        constraints += [cp.norm(T[k, :]) <= T_max]
        constraints += [cp.norm(T[k, :]) >= T_min]  # if engine on
        constraints += [cp.norm(T[k, :]) <= gamma[k]]  # SOCP form
        # Thrust cone constraint (glide slope)
        constraints += [r[k, 2] >= np.tan(gamma_max) * cp.norm(r[k, :2] - r_target[:2])]
    
    # Solve
    prob = cp.Problem(objective, constraints)
    prob.solve(solver=cp.ECOS, verbose=False)
    
    return T.value, r.value, v.value
```

