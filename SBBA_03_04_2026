-- Core algebraic specification (Haskell-style pseudocode)
data Sort = Input | Output | Memory | Effect | Prop deriving (Eq, Show)

data Type = TVar String | TApp Sort [Type] deriving (Eq, Show)

data ToolSig = ToolSig {
    name     :: String,
    inputs   :: [(String, Type)],
    output   :: Type,
    effects  :: [LTL Formula],      -- LTL predicates over execution
    resources :: (Double, Double)   -- (time_bound, memory_bound)
} deriving (Eq, Show)

-- Tool graph as typed term with annotations
data ToolGraph = TG {
    term       :: Term ToolSig,      -- from initial algebra T_Σ
    typing     :: Derivation,         -- Γ ⊢ t : τ
    safety     :: LTL Formula,        -- φ_safe over traces
    fitness    :: Double,            -- f(G) = 𝔼[ρ(τ|G)]
    phylogeny  :: PhyloID            -- node in evolutionary tree
} deriving (Eq, Show)

-- Oracle self-evaluation functional
rho :: Trajectory -> OracleConfig -> Double
rho tau cfg = 
    alpha * logOddsMargin tau cfg
  + beta  * (1 - normalizedEntropy (selfConsistencySamples tau cfg))
  + gamma * fromEnum (execVerification tau)

-- Phylogenetic evolutionary operator
phyloForge :: 
    Population ToolGraph ->          -- [G₁, ..., Gₙ]
    FitnessScores ->                -- [f₁, ..., fₙ]
    EvolutionConfig ->              -- (s, ε_mut, δ_niche, ...)
    Distribution ToolGraph          -- Δ(𝒢)
```

### 4.3 Algorithm: Perpetual Loop with Complexity Analysis

```python
from typing import Generic, TypeVar, List, Optional
from dataclasses import dataclass
import numpy as np

@dataclass
class SBBAConfig:
    tournament_size: int = 3
    mutation_rate: float = 0.1
    crossover_rate: float = 0.7
    speciation_threshold: float = 0.3
    adaptation_threshold: float = 0.6
    max_population: int = 50
    alpha: float = 0.4  # ρ weights
    beta: float = 0.4
    gamma: float = 0.2

class PhylogeneticForge:
    """Steady-state genetic algorithm with speciation"""
    
    def evolve(self, 
               population: List[ToolGraph], 
               fitness: List[float],
               oracle: Oracle) -> List[ToolGraph]:
        """
        One generation of phylogenetic evolution.
        
        Complexity: O(n · s · T_exec + n² · d_edit)
        where n = population size, s = tournament size, 
                T_exec = tool execution time, d_edit = graph edit distance
        """
        new_pop = population.copy()
        
        # Tournament selection (O(n · s)) - Lemma 3.1.1
        parents = self._tournament_select(population, fitness, self.cfg.tournament_size)
        
        # Variation operators
        for _ in range(len(population) // 2):
            if np.random.rand() < self.cfg.mutation_rate:
                offspring = self._mutate(parents, oracle)  # O(T_exec)
            elif np.random.rand() < self.cfg.crossover_rate:
                p1, p2 = np.random.choice(parents, 2, replace=False)
                offspring = self._crossover(p1, p2)  # O(d_edit)
            else:
                continue
                
            # Speciation: maintain diversity (O(n · d_edit))
            if self._is_novel(offspring, new_pop, self.cfg.speciation_threshold):
                new_pop.append(offspring)
                self.phylogeny.add_node(offspring, parents)
                
        # Elitism + truncation: O(n log n)
        new_fitness = [self._evaluate(g, oracle) for g in new_pop]
        elite_idx = np.argsort(new_fitness)[-self.cfg.max_population:]
        return [new_pop[i] for i in elite_idx]
```

**Perpetual Loop Pseudocode:**
```
Initialize: frozen π₀, initial tool graph G₀, memory M₀, phylogeny tree Φ

while environment is live:
    τ ← π₀.rollout(G_current, M_current)          // black-box action: O(T_rollout)
    r ← SelfEvaluateOracle(τ)                     // pure output signals: O(k · T_query)
    
    if r < threshold:
        // Phylogenetic evolution: O(n · s · T_exec + n² · d_edit)
        offspring ← PhylogeneticForge.mutate_crossover(G_current, Φ, r)
        G_new ← SelectFittest(offspring ∪ G_current, r)
        
        // Memory adaptation: O(T_mem_adapt)
        M_new ← MemoryFabric.adapt(M_current, τ, r)
        
        // Update phylogeny: O(log n)
        UpdatePhylogeny(Φ, G_new)
    
    Deploy G_new, M_new for next rollout
```

**Overall Complexity per Epoch:** $O(T_{\text{rollout}} + k \cdot T_{\text{query}} + n \cdot s \cdot T_{\text{exec}} + n^2 \cdot d_{\text{edit}} + T_{\text{mem\_adapt}})$

With typical parameters ($n=50, s=3, k=5$), this is dominated by tool execution and remains feasible for real-time deployment.

