**PyTorch Core Sampler Specification** (energy-guided diffusion):

```python
# models/htc_sampler.py
class HierarchicalThermodynamicSampler(nn.Module):
    """
    Main HTC sampler with energy-constrained generation.
    
    Invariants:
    - Energy of generated clips remains bounded: E(x_t) ≤ ε
    - Memory updates compress information: I(m_t; x_t) ≤ β
    - Physical constraints are preserved under small perturbations
    """
    
    def __init__(self, config: HTCConfig):
        super().__init__()
        self.config = config
        
        # Base video generator (diffusion/transformer)
        self.generator = VideoDiffusionModel()
        
        # Frozen feature extractors
        self.feature_extractor = FeatureExtractors()
        
        # Energy functional
        self.energy_functional = EnergyFunctional(config)
        
        # Memory system
        self.memory = SlotBasedMemory(config)
        
        # Energy guidance adapter
        self.energy_adapter = nn.Sequential(
            nn.Linear(1, 128),
            nn.LayerNorm(128),
            nn.GELU(),
            nn.Linear(128, self.generator.condition_dim)
        )
    
    def energy_guided_step(self, x_t, t, memory, prev_clip=None):
        """
        Perform one step of energy-guided diffusion sampling.
        
        Invariant: If Energy(x_t) ≤ ε before step, then Energy(x_{t+1}) ≤ ε + δ
        where δ accounts for numerical precision.
        """
        # Base diffusion prediction
        pred_noise = self.diffusion_model(x_t, t, cond=memory)
        x_pred = self.scheduler.step(pred_noise, t, x_t)
        
        # Energy computation (with autograd)
        video_pred = self.vae.decode(x_pred)
        energy, components = self.energy_functional(
            video_pred, prev_clip, memory, self.feature_extractor
        )
        
        # Energy-guided correction (projection toward low-energy manifold)
        if energy > self.config.energy_epsilon:
            grad = torch.autograd.grad(energy, x_pred, retain_graph=True)[0]
            grad_norm = grad.norm(dim=(1,2,3), keepdim=True).clamp(min=1e-8)
            x_pred = x_pred - self.config.guidance_scale * grad / grad_norm
        
        # Classifier-free guidance with energy condition
        energy_cond = self.energy_adapter(energy.unsqueeze(-1))
        combined_cond = torch.cat([memory, energy_cond], dim=-1)
        
        return self.diffusion_model.denoise(x_t, t, combined_cond)
```

