        L_prosody = mse(z.p, extract_prosody(batch.audio))
        L_cmi = club_loss(z.p, z.s, z.c)
        L_orth = orthogonality_penalty(z.c, z.p, z.s)
        L_contract = contractive_penalty(A_bar)
        
        # Predictive loss
        for tau in [200,300,400,500]:
            z_pred = predictive_head(z[t_pred], partial_text, tau)
            L_predict += mse(z[t_pred+tau], z_pred)
        
        L_total = weighted_sum(losses)
        L_total.backward()
        clip_grad_norm(1.0)
        optimizer.step()
        
        # Update CLUB network
        club_loss = -log_likelihood(z.s | z.p, z.c)
        club_loss.backward()
        club_optimizer.step()
