def smooth_cutoff(r, Rc, epsilon=0.1):
    """
    C^infty smooth cutoff function: cosine taper with analytic continuation.
    For r <= Rc-epsilon: 1; for r >= Rc: 0; smooth transition in between.
    """
    r = torch.as_tensor(r)
    x = (r - (Rc - epsilon)) / epsilon
    # Smooth step: 0 for x<=0, 1 for x>=1, and a C^infty bump in between
    def smoothstep(x):
        return torch.where(x <= 0, torch.tensor(0.0),
                 torch.where(x >= 1, torch.tensor(1.0),
                 6*x**5 - 15*x**4 + 10*x**3))
    return 1 - smoothstep(x)

