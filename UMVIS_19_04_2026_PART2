D.1 Full Training Loop

```python
# Configuration
config = {
    'd_z': 1024, 'd_c': 512, 'd_p': 256, 'd_s': 128, 'd_eps': 128,
    'num_layers': 10, 'state_dim': 16,
    'batch_size': 128, 'lr': 3e-4, 'warmup': 10000, 'total_steps': 500000,
    'predictive_horizons': [200, 300, 400, 500],  # ms
    'loss_weights': {'text': 1.0, 'speech': 1.0, 'align': 0.5, 'prosody': 0.3,
                     'cmi': 0.1, 'orth': 0.05, 'anchor': 0.2, 'contract': 0.01,
                     'predict': 0.5}
}

# Initialize models
speech_encoder = ConvEncoder(...)
text_encoder = TextEncoder(...)
ldvs = LDVSCore(num_layers=10, d_z=1024, state_dim=16, ...)
text_decoder = CTCHead(d_c, vocab_size=32000)
speech_decoder = EnCodecDecoder(...)
vocoder = HiFiGANVocoder(...)
predictive_head = PredictiveHead(d_z, d_text, horizons=[200,300,400,500])
club_network = CLUBNetwork(d_s, d_p+d_c)  # For CMI estimation

# Optimizers
optimizer = AdamW(all_params, lr=config['lr'], weight_decay=0.01)
club_optimizer = AdamW(club_network.parameters(), lr=1e-4)

# Training loop
for step in range(config['total_steps']):
    batch = next(dataloader)  # dict with audio, text, speaker_id, etc.
    
    # Initialize latents
    z_c = text_encoder(batch['partial_text']) if 'partial_text' in batch else torch.zeros(batch['B'], d_c)
    z_p = vamprior.sample((batch['B'],))
    z_s = speaker_embedding(batch['speaker_id'])
    z_eps = torch.zeros(batch['B'], d_eps)
    z = torch.cat([z_c, z_p, z_s, z_eps], dim=-1)  # [B, d_z]
    
    # Storage for losses
    losses = {k: 0.0 for k in config['loss_weights']}
    
    # Unroll over time
    T = batch['audio'].shape[1] // 320  # number of 20ms frames
    z_history = []
    for t in range(T):
        audio_chunk = batch['audio'][:, t*320:(t+1)*320]
        u_t = speech_encoder(audio_chunk)  # [B, d_z]
        
        z = ldvs.step(z, u_t)  # one SSM step
        z_history.append(z)
        
        # Anchor loss at phoneme boundaries
        if t in batch['phoneme_boundaries']:
            losses['anchor'] += F.mse_loss(project_c(z[:, :d_c]), project_p(z[:, d_c:d_c+d_p]))
    
    # Stack latents
    z_seq = torch.stack(z_history, dim=1)  # [B, T, d_z]
    z_c_seq = z_seq[:, :, :d_c]
    z_p_seq = z_seq[:, :, d_c:d_c+d_p]
    z_s_seq = z_seq[:, :, d_c+d_p:d_c+d_p+d_s]
    
    # Text loss (CTC)
    logits = text_decoder(z_c_seq)  # [B, T, vocab]
    losses['text'] = ctc_loss(logits, batch['text_tokens'], input_lengths, target_lengths)
    
    # Speech reconstruction loss
    recon_audio = speech_decoder(z_seq) + vocoder
    losses['speech'] = reconstruction_loss(recon_audio, batch['audio'])
    
    # Alignment loss (Soft-DTW + InfoNCE)
    text_emb = text_encoder(batch['full_text'])  # [B, L, d_text]
    losses['align'] = soft_dtw_loss(z_c_seq, text_emb) + infonce_loss(z_c_seq, text_emb)
    
    # Prosody supervision
    f0_gt, energy_gt = extract_prosody(batch['audio'])
    f0_pred, energy_pred = prosody_head(z_p_seq)
    losses['prosody'] = F.mse_loss(f0_pred, f0_gt) + F.mse_loss(energy_pred, energy_gt)
    
    # CMI loss (CLUB)
    # We want to minimize I(Z_p; Z_s | Z_c)
    club_input = torch.cat([z_p_seq.detach(), z_c_seq.detach()], dim=-1)
    log_q = club_network(z_s_seq, club_input)  # log q(s | p, c)
    # Positive samples: from joint
    pos_loss = -log_q.mean()
    # Negative samples: shuffle p and c across batch
    z_p_shuf = z_p_seq[torch.randperm(B)]
    z_c_shuf = z_c_seq[torch.randperm(B)]
    club_input_neg = torch.cat([z_p_shuf, z_c_shuf], dim=-1)
    log_q_neg = club_network(z_s_seq, club_input_neg)
    neg_loss = log_q_neg.mean()
    losses['cmi'] = pos_loss - neg_loss
    
    # Orthogonality penalty
    losses['orth'] = orthogonality_penalty(z_c_seq, z_p_seq, z_s_seq)
    
    # Contractive penalty
    A_bar_matrices = ldvs.get_A_bar()  # list of [B, d_z, d_z] or diagonal
    losses['contract'] = sum(torch.norm(A, p=2) for A in A_bar_matrices) / len(A_bar_matrices)
    
    # Predictive loss
    for tau_ms in config['predictive_horizons']:
        tau_steps = int(tau_ms / 20)  # convert to frames
        for t in range(T - tau_steps):
            z_future_pred = predictive_head(z_seq[:, t, :], batch['partial_text'], tau_ms)
            losses['predict'] += F.mse_loss(z_future_pred, z_seq[:, t+tau_steps, :])
    losses['predict'] /= (len(config['predictive_horizons']) * (T - max_steps))
    
    # Total loss
    total_loss = sum(config['loss_weights'][k] * losses[k] for k in losses)
    
    # Backward
    total_loss.backward()
    torch.nn.utils.clip_grad_norm_(all_params, 1.0)
    optimizer.step()
    optimizer.zero_grad()
    
    # Update CLUB network separately (to avoid conflict)
    club_loss = -log_q.mean()  # maximize likelihood of true conditional
    club_loss.backward()
    club_optimizer.step()
    club_optimizer.zero_grad()
    
    # Logging
    if step % 100 == 0:
        print(f"Step {step}: total_loss={total_loss.item():.4f}, " + 
              ", ".join(f"{k}={v.item():.4f}" for k,v in losses.items()))
```

D.2 Masked Prosody Model (MPM) Pretraining

```python
def pretrain_mpm(num_steps=100000):
    # Simplified encoder-decoder for prosody prediction
    encoder = ConvEncoder(...)  # same as speech encoder
    prosody_decoder = ProsodyDecoder(d_z, output_dim=2)  # F0 and energy
    
    optimizer = AdamW(list(encoder.parameters()) + list(prosody_decoder.parameters()), lr=1e-3)
    
    for step in range(num_steps):
        audio = sample_audio_batch(batch_size=64, duration=10.0)  # [B, 160000]
        
        # Extract ground truth prosody
        f0_gt, energy_gt = extract_prosody(audio)  # [B, T]
        
        # Encode audio
        h = encoder(audio)  # [B, T_enc, d_z]
        
        # Apply masking (random spans of 100-300ms)
        mask = random_span_mask(h.shape, span_len_range=(5,15), mask_prob=0.15)
        h_masked = h * (1 - mask.unsqueeze(-1))
        
        # Predict prosody
        pred = prosody_decoder(h_masked)  # [B, T_enc, 2]
        f0_pred, energy_pred = pred[..., 0], pred[..., 1]
        
        # Loss only on masked positions
        loss_f0 = F.mse_loss(f0_pred[mask], f0_gt[mask])
        loss_energy = F.mse_loss(energy_pred[mask], energy_gt[mask])
        loss = loss_f0 + loss_energy
        
        optimizer.zero_grad()
        loss.backward()
        optimizer.step()
        
        if step % 1000 == 0:
            print(f"MPM Step {step}: loss={loss.item():.4f}")
    
    return encoder, prosody_decoder
