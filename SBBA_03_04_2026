### 5.1 Oracle Self-Evaluation Module (`rho.py`)

```python
"""
rho.py — Oracle self-evaluation functional (Definition 3.2.1)
Implements the information-theoretic reward signal with finite-sample guarantees.
"""

import numpy as np
from scipy import stats
from typing import List, Callable, Optional
from dataclasses import dataclass

@dataclass
class OracleConfig:
    alpha: float = 0.4    # log-odds weight
    beta: float = 0.4     # self-consistency weight  
    gamma: float = 0.2    # execution verification weight
    k_consistency: int = 5  # number of self-consistency samples
    epsilon: float = 1e-6  # numerical stability

class SelfEvaluationOracle:
    """
    Black-box self-evaluation functional ρ : ℋ → [0,1]
    
    Theorem 3.2.3: With k ≥ 2|𝒴|² log(4/δ)/ε² samples,
    ℙ(|ρ̂(τ) - u(τ)| ≥ ε) ≤ δ + 2exp(-2kε²/|𝒴|²)
    """
    
    def __init__(self, config: OracleConfig, outcome_space_size: int):
        self.cfg = config
        self.V = outcome_space_size  # |𝒴| for entropy bounds
        
    def __call__(self, 
                 trajectory: dict,
                 oracle_query: Callable[[str], dict],
                 verified_outcome: Optional[str] = None) -> float:
        """
        Compute ρ(τ) using only black-box oracle queries.
        """
        # Term 1: Log-odds margin (proper scoring rule)
        if verified_outcome is not None:
            log_odds = self._log_odds_margin(trajectory, verified_outcome, oracle_query)
        else:
            log_odds = 0.0
            
        # Term 2: Normalized self-consistency entropy (Lemma 3.2.2)
        samples = [oracle_query(trajectory['prompt'])['output'] 
                  for _ in range(self.cfg.k_consistency)]
        entropy_term = self._normalized_consistency_entropy(samples)
        
        # Term 3: Deterministic execution verification
        exec_term = float(self._verify_execution(trajectory))
        
        # Weighted combination (Theorem 3.2.3 guarantees identifiability)
        reward = (self.cfg.alpha * np.clip(log_odds, -10, 10) +
                 self.cfg.beta * entropy_term + 
                 self.cfg.gamma * exec_term)
        
        return self._normalize(reward)
    
    def _log_odds_margin(self, 
                        trajectory: dict,
                        verified: str, 
                        query: Callable[[str], dict]) -> float:
        """Compute log p(y_verified|τ) / p(y_baseline|τ)"""
        result = query(trajectory['prompt'])
        log_p_verified = result.get('log_prob', 0.0)
        log_p_baseline = -np.log(self.V + self.cfg.epsilon)
        return log_p_verified - log_p_baseline
    
    def _normalized_consistency_entropy(self, samples: List[str]) -> float:
        """Compute 1 - Ĥ_k / log|𝒴| with concentration bound (Lemma 3.2.2)"""
        unique, counts = np.unique(samples, return_counts=True)
        probs = counts / len(samples)
        entropy = stats.entropy(probs, base=2)
        max_entropy = np.log2(self.V)
        consistency = 1.0 - (entropy / (max_entropy + self.cfg.epsilon))
        return np.clip(consistency, 0.0, 1.0)
    
    def _verify_execution(self, trajectory: dict) -> bool:
        """Deterministic verification: code pass/fail, API return codes"""
        for step in trajectory.get('tool_calls', []):
            if step.get('status') != 'success':
                return False
        return True
    
    def _normalize(self, raw: float, 
                  empirical_min: float = -2.0,
                  empirical_max: float = 3.0) -> float:
        """Affine normalization to [0,1] using pilot statistics"""
        normalized = (raw - empirical_min) / (empirical_max - empirical_min + self.cfg.epsilon)
        return np.clip(normalized, 0.0, 1.0)
