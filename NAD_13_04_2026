E.2 Training the Lagrangian and Projection Network

```python
# Hyperparameters
lambda_constraint = 1.0
window_size = 10
learning_rate = 1e-4

def del_residual_window(Q, L_theta, sigma, window_size):
    """Compute DEL residuals on a sliding window."""
    B, Np1, d = Q.shape
    N = Np1 - 1
    residuals = []
    for start in range(0, N - window_size + 1):
        Q_win = Q[:, start:start+window_size+1, :]  # shape (B, w+1, d)
        q = Q_win[:, :-1, :]
        q_next = Q_win[:, 1:, :]
        v = (q_next - q) / dt
        # Compute discrete Lagrangian and derivatives
        L_val, (grad_q, grad_q_next) = L_theta.with_gradients(q, v)  # custom autodiff
        r = grad_q_next[:, 1:, :] + grad_q[:, :-1, :]  # shape (B, w-1, d)
        # Add noise covariance contribution (simplified)
        sigma_mid = 0.5 * (sigma(q) + sigma(q_next))
        noise_cov = torch.einsum('bkid,bkjd->bkij', sigma_mid, sigma_mid)
        r_stoch = r + torch.sqrt(noise_cov) @ torch.randn_like(r)
        residuals.append(torch.sum(r_stoch**2, dim=(1,2)))
    return torch.stack(residuals, dim=1).mean(dim=1)  # average over windows

# Training step
for batch in dataloader:
    Q_obs = batch  # observed trajectories (clean or noisy)
    # Compute expected action (deterministic)
    v_obs = (Q_obs[:, 1:] - Q_obs[:, :-1]) / dt
    S_theta = L_theta(Q_obs[:, :-1], v_obs).sum(dim=1)
    # Constraint loss
    F_loss = del_residual_window(Q_obs, L_theta, sigma, window_size)
    loss = S_theta.mean() + lambda_constraint * F_loss.mean()
    loss.backward()
    optimizer_L.step()

    # Train amortised projection network on current L_theta
    with torch.no_grad():
        target_grad = torch.autograd.grad(F_loss.sum(), Q_obs, create_graph=False)[0]
    pred_grad = proj_net(Q_obs, t)  # t is diffusion time
    proj_loss = F.mse_loss(pred_grad, target_grad)
    proj_loss.backward()
    optimizer_proj.step()
```

E.3 Projected Score Dynamics (PSD) Sampling

```python
def sample_psd(score_net, proj_net, L_theta, sigma, N_steps, gamma_schedule, beta_schedule):
    B = batch_size
    Q = torch.randn(B, N+1, d)  # initial noise from prior
    dt = T / N_steps
    for i in range(N_steps):
        t = T - i * dt
        beta_t = beta_schedule(t)
        gamma_t = gamma_schedule(t)
        # Standard reverse diffusion drift
        score = score_net(Q, t)
        v_diff = -0.5 * beta_t * Q - beta_t * score
        # Projection drift (amortised)
        proj_grad = proj_net(Q, t)
        # Optional: clip gradient
        proj_grad = torch.clamp(proj_grad, -tau_clip, tau_clip)
        drift = v_diff - gamma_t * proj_grad
        # Euler-Maruyama step
        noise = torch.randn_like(Q)
        Q = Q + drift * dt + torch.sqrt(beta_t * dt) * noise
    return Q
```

E.4 NAD‑EnKF Coupling (Pseudocode)

```python
def nad_enkf_step(ensemble_Q, y_obs, H, R, gamma_schedule, beta_schedule):
    # ensemble_Q shape: (M, N+1, d)
    # Forecast: propagate each ensemble member with PSD (single step or full trajectory)
    for m in range(M):
        ensemble_Q[m] = sample_psd_single_step(ensemble_Q[m], ...)  # forward in time

    # Analysis at observation time k
    Q_k = ensemble_Q[:, k, :]  # states at time k
    # EnKF update
    Q_mean = Q_k.mean(dim=0)
    A = Q_k - Q_mean  # anomalies
    P_f = (A.T @ A) / (M - 1)
    K = P_f @ H.T @ torch.inverse(H @ P_f @ H.T + R)
    y_pert = y_obs + torch.randn(M, *y_obs.shape) @ torch.cholesky(R)
    Q_k_analysis = Q_k + (y_pert - Q_k @ H.T) @ K.T
    ensemble_Q[:, k, :] = Q_k_analysis
    return ensemble_Q
```

E.5 Inverse Problem: Learning \theta via Score Matching

To avoid estimating Z_\theta, we can use denoising score matching. The target density p_\theta(Q) \propto e^{-\mathcal{E}_\theta(Q)} has score \nabla_Q \log p_\theta(Q) = -\nabla_Q \mathcal{E}_\theta(Q). We train a score network s_\theta to match this target score.

```python
def energy_score_loss(Q_obs, L_theta, sigma, lambda_constraint, score_net):
    Q_obs.requires_grad_(True)
    S_theta = L_theta(Q_obs[:, :-1], (Q_obs[:, 1:]-Q_obs[:, :-1])/dt).sum()
    F_val = del_residual_full(Q_obs, L_theta, sigma)  # full trajectory constraint
    energy = S_theta + lambda_constraint * F_val.sum()
    true_score = -torch.autograd.grad(energy, Q_obs, create_graph=True)[0]
    pred_score = score_net(Q_obs, t=0)  # t=0 for clean data
    return F.mse_loss(pred_score, true_score)
```

This loss can be minimised over \theta (parameters of L_\theta and \sigma) and the score network parameters jointly, providing a tractable approach to learning the stochastic Lagrangian from data.

