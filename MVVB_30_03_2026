    # DPF: differential pathlength factor (approximate)
    # Constants
    epsilon = {'HbO': {760: 1486, 850: 2514}, 'HbR': {760: 3807, 850: 1806}}
    DPF = 6.0  # typical for adult head
    n_channels, n_time = intensity_data.shape
    delta_OD = -np.log10(intensity_data / np.mean(intensity_data, axis=1, keepdims=True))
    # Solve for HbO and HbR at each time point
    HbO = np.zeros((n_channels, n_time))
    HbR = np.zeros((n_channels, n_time))
    for ch in range(n_channels):
        A = np.array([[epsilon['HbO'][wavelengths[0]], epsilon['HbR'][wavelengths[0]]],
                      [epsilon['HbO'][wavelengths[1]], epsilon['HbR'][wavelengths[1]]]])
        for t in range(n_time):
            y = delta_OD[ch, t] / (DPF * source_detector_dist)
            conc = np.linalg.lstsq(A, y, rcond=None)[0]
            HbO[ch, t] = conc[0]
            HbR[ch, t] = conc[1]
    # Bandpass filter 0.01-0.5 Hz
    nyq = fs / 2
    b, a = butter(2, [0.01/nyq, 0.5/nyq], btype='band')
    HbO_filt = filtfilt(b, a, HbO, axis=1)
    return HbO_filt, HbR_filt
```

D.3 Wavelet Coherence Computation

```python
import pywt

def wavelet_coherence(x, y, dt=0.25, scales=None):
    """
    Compute wavelet coherence between two signals.
    x, y: time series (same length)
    dt: sampling interval (seconds)
    scales: array of scales (if None, use pywt's default)
    Returns: coherence (time x scales), scales
    """
    if scales is None:
        scales = np.arange(1, 64)  # example
    # Compute CWT
    coef_x, freqs = pywt.cwt(x, scales, 'morl', dt)
    coef_y, _ = pywt.cwt(y, scales, 'morl', dt)
    # Smooth in time and scale (simple moving average)
    # For brevity, we skip smoothing here; use pywt's built-in or manual convolution
    cross = coef_x * np.conj(coef_y)
    power_x = np.abs(coef_x)**2
    power_y = np.abs(coef_y)**2
    # Smooth
    from scipy.ndimage import uniform_filter
    smooth_cross = uniform_filter(cross, size=(5, 5))
    smooth_px = uniform_filter(power_x, size=(5, 5))
    smooth_py = uniform_filter(power_y, size=(5, 5))
    coherence = np.abs(smooth_cross)**2 / (smooth_px * smooth_py + 1e-12)
    return coherence, freqs
```

D.4 Convergent Cross Mapping Implementation

```python
def ccm(series_a, series_b, E, tau, library_lengths):
    """
    series_a, series_b: time series (same length)
    E: embedding dimension
    tau: time delay
    library_lengths: list of library sizes (as fraction of total length)
    Returns: cross_map_skill for a->b and b->a
    """
    def embed(series, E, tau):
        N = len(series)
        L = N - (E-1)*tau
        emb = np.zeros((L, E))
        for i in range(L):
            for j in range(E):
                emb[i, j] = series[i + j*tau]
        return emb

    # Embed both series
    emb_a = embed(series_a, E, tau)
    emb_b = embed(series_b, E, tau)

    def cross_map(source, target, lib_len):
        # source: embedded manifold used as library
        # target: embedded manifold used as target (we map from source to target)
        # returns correlation between predicted and actual target
        N = len(source)
        indices = np.arange(N)
        # Use first lib_len points as library
        lib_indices = indices[:lib_len]
        pred = np.zeros(N - lib_len)
        actual = np.zeros(N - lib_len)
        # For each point in the prediction set (the rest)
        for i, idx in enumerate(indices[lib_len:]):
            # Find nearest neighbors in library (Euclidean distance)
            dists = np.sum((source[lib_indices] - source[idx])**2, axis=1)
            nn_idx = lib_indices[np.argsort(dists)[:E+1]]
            # Weighted average of target values at those neighbors
            # For simplicity, we use unweighted mean
            pred[i] = np.mean(target[nn_idx])
            actual[i] = target[idx]
        return np.corrcoef(pred, actual)[0,1]

    skills_a_to_b = []
    skills_b_to_a = []
    for L in library_lengths:
        skill_a_to_b = cross_map(emb_a, emb_b, L)
        skill_b_to_a = cross_map(emb_b, emb_a, L)
        skills_a_to_b.append(skill_a_to_b)
        skills_b_to_a.append(skill_b_to_a)
    return skills_a_to_b, skills_b_to_a
