# Pseudo‑code for real‑time system

class EEGAcquisition:
    def __init__(self, n_channels=64, sampling_rate=250):
        self.buffer = RingBuffer(maxlen=256)  # 1 second

    def acquire(self):
        data = read_from_hardware()
        self.buffer.append(data)
        return self.buffer.get_window()

class Preprocessing:
    def __init__(self):
        self.fir_coeffs = design_bandpass(0.5, 50, fs=250)
        self.ica = ICA(n_components=64)

    def process(self, data):
        filtered = lfilter(self.fir_coeffs, data, axis=0)
        cleaned = self.ica.apply(filtered, exclude_artifacts=True)
        return cleaned

class RiemannianFeatures:
    def __init__(self, n_channels, ref_cov):
        self.ref_cov = ref_cov
        self.ref_sqrt = sqrtm(ref_cov)
        self.ref_inv_sqrt = inv(self.ref_sqrt)

    def compute_covariance(self, data):
        centered = data - data.mean(axis=1, keepdims=True)
        return (centered @ centered.T) / (data.shape[1] - 1)

    def tangent_projection(self, cov):
        M = self.ref_inv_sqrt @ cov @ self.ref_inv_sqrt
        logM = logm(M)
        tangent = self.ref_sqrt @ logM @ self.ref_sqrt
        return vect(tangent)  # with √2 scaling

