    M              population size
    G_max          maximum generations
    p_c            crossover probability
    p_m            mutation probability
    p_global       global mutation probability (part of mutation)
    p_local        probability to perform gradient descent on continuous parameters
    γ_0            initial step size for gradient descent
    D_max          maximum tree depth
    C              finite set of rational constants
    δ_max, δ_min, λ  diversity schedule parameters
    r              injection count
    ε, K           hypervolume improvement tolerance and stagnation limit
    data           observations {(x_i, y_i)}_{i=1}^N
Output:
    Pareto front F (set of non-dominated individuals)

// Initialization
P = empty list
for i = 1 to M:
    T = generate_random_tree(G_phys, D_max, C)
    c = extract_initial_constants(T, C)   // vector of constant values
    P.append( (T, c) )

t = 0
best_hypervolume = -∞
no_improve_count = 0
global_pareto_set = empty set

while t < G_max and no_improve_count < K:
    // Offspring generation
    Q = empty list
    for i = 1 to M:
        // Parent selection (tournament based on Pareto rank and crowding distance)
        parent1 = tournament_selection(P, 2)
        parent2 = tournament_selection(P, 2)
        if random() < p_c:
            child = crossover(parent1, parent2)
        else:
            child = clone(parent1)
        if random() < p_m:
            child = mutate(child, p_global)   // includes global mutation with prob p_global
        if random() < p_local:
            // perform a few gradient descent steps on child.c
            for step in 1..num_gradient_steps:
                child.c = child.c - γ_t * ∇_c L_emp(child)   // γ_t = γ_0/(1+t)
        if not valid(child):   // type/dimension check
            child = generate_random_individual(G_phys, D_max, C)
        Q.append(child)
    
    // Combined population and non-dominated sorting
    R = P ∪ Q
    fronts = non_dominated_sort(R)   // returns list of fronts F1, F2, ...
    
    // Build next population with elitist preservation of global Pareto set
    P_next = empty list
    F1 = fronts[0]
    if |F1| > M:
        // Keep all global Pareto individuals that are in F1
        keep = [ind for ind in F1 if ind in global_pareto_set]
        remaining_slots = M - len(keep)
        # sort remaining F1 individuals by crowding distance descending
        others = sorted([ind for ind in F1 if ind not in global_pareto_set],
                        key=crowding_distance, reverse=True)
        P_next = keep + others[:remaining_slots]
    else:
        P_next = F1
        front_idx = 1
        while len(P_next) + len(fronts[front_idx]) <= M:
            P_next = P_next + fronts[front_idx]
            front_idx += 1
        if len(P_next) < M:
            last_front = fronts[front_idx]
            sort last_front by crowding distance descending
            P_next = P_next + last_front[:M - len(P_next)]
    
    // Update global Pareto set: any individual in F1 that is not dominated by any known individual becomes part of global_pareto_set
    for ind in F1:
        if not any(other dominates ind for other in global_pareto_set):
            global_pareto_set.add(ind)
    // Also remove individuals from global_pareto_set that become dominated by new ones
    global_pareto_set = {ind for ind in global_pareto_set if not any(other dominates ind for other in F1)}
    
    // Diversity injection
    δ_t = max(δ_min, δ_max * exp(-λ * t))
    d_avg = average_tree_edit_distance(P_next)   // using canonical forms S(T)
    if d_avg < δ_t:
        candidates = [generate_random_individual(G_phys, D_max, C) for _ in range(r)]
        scores = []
        for cand in candidates:
            score = sum(tree_edit_distance(S(cand.T), S(ind.T)) for ind in P_next)
            scores.append(score)
        best_candidates = select_top(r, candidates, scores)   // indices of largest scores
        // sort P_next by crowding distance ascending
        P_next.sort(key=crowding_distance)
        // replace first r individuals
        P_next = P_next[r:] + best_candidates
    
    P = P_next
    
    // Compute hypervolume and check termination
    current_hypervolume = hypervolume(P, reference_point=(L_max, Ω_max))
    if current_hypervolume > best_hypervolume + ε:
        best_hypervolume = current_hypervolume
        no_improve_count = 0
    else:
        no_improve_count += 1
    t += 1

return non_dominated(P)
