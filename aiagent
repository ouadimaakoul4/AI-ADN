6.3 Option C: Full Programmatic (Python + API)

CrewAI Implementation:

```python
from crewai import Agent, Task, Crew, Process
from langchain.tools import Tool
import json
from datetime import datetime

# Load memory systems
def load_registry():
    with open('THESIS_REGISTRY.json', 'r') as f:
        return json.load(f)

def save_registry(registry):
    with open('THESIS_REGISTRY.json', 'w') as f:
        json.dump(registry, f, indent=2)

# Define agents
orchestrator = Agent(
    role='PTA 3.0 Orchestrator',
    goal='Coordinate defense-ready PhD thesis development with zero hallucination tolerance',
    backstory='''You are the lead research manager for a PhD thesis. You coordinate 
    specialized sub-agents, maintain rigorous quality standards, and ensure all outputs 
    are source-grounded and defense-ready.''',
    verbose=True,
    allow_delegation=True,
    memory=True
)

planner = Agent(
    role='Planner & Structurer',
    goal='Create rigorous thesis architecture and chapter outlines',
    backstory='Expert in academic structure and research design',
    verbose=True
)

literature_synthesizer = Agent(
    role='Literature Synthesizer & Gap Analyst',
    goal='Build grounded theoretical framework with verified sources only',
    backstory='''Specialist in systematic literature review with absolute commitment 
    to source verification. Never synthesizes without approved sources.''',
    verbose=True
)

methodologist = Agent(
    role='Methodologist',
    goal='Design rigorous, defensible research methodology',
    backstory='Expert in research methods across disciplines',
    verbose=True
)

writer = Agent(
    role='Writer & Drafter',
    goal='Produce publication-quality academic prose matching user voice',
    backstory='''Academic writer specializing in consistent voice maintenance and 
    rigorous source integration''',
    verbose=True
)

critic = Agent(
    role='Critic & Editor',
    goal='Apply comprehensive rubric-based critique to all deliverables',
    backstory='Ruthless quality guardian ensuring defense readiness',
    verbose=True
)

defense_preparer = Agent(
    role='Defense Preparer',
    goal='Create comprehensive viva preparation materials',
    backstory='Expert in doctoral examination preparation',
    verbose=True
)

# Define tasks
def create_chapter_tasks(chapter_num, chapter_title, registry):
    return [
        Task(
            description=f'Create detailed outline for Chapter {chapter_num}: {chapter_title}',
            agent=planner,
            expected_output='Chapter outline with research questions and structure'
        ),
        Task(
            description=f'Identify and propose sources for Chapter {chapter_num}',
            agent=literature_synthesizer,
            expected_output='List of 5+ candidate sources with DOI and relevance'
        ),
        Task(
            description=f'Draft Chapter {chapter_num} sections',
            agent=writer,
            expected_output='Draft sections matching voice profile',
            context=[registry]  # Pass registry for consistency
        ),
        Task(
            description=f'Critique Chapter {chapter_num} draft',
            agent=critic,
            expected_output='Rubric-based critique with revision suggestions'
        )
    ]

# Create crew
crew = Crew(
    agents=[orchestrator, planner, literature_synthesizer, 
            methodologist, writer, critic, defense_preparer],
    tasks=[],  # Populated dynamically
    process=Process.hierarchical,
    memory=True,
    verbose=True
)

# Execution
if __name__ == "__main__":
    registry = load_registry()
    
    # Example: Start Chapter 2
    chapter_tasks = create_chapter_tasks(2, "Literature Review", registry)
    crew.tasks = chapter_tasks
    
    result = crew.kickoff()
    
    # Update registry
    registry['chapters'].append({
        'chapter_number': 2,
        'title': 'Literature Review',
        'status': 'draft',
        'last_updated': datetime.now().isoformat()
    })
    save_registry(registry)
    
    print(result)
```

Pros: Full automation, state persistence, scalable
Cons: Requires coding expertise, API costs

