This appendix provides illustrative Python code implementing the core CES update logic and a simulation of the Mars case study. The code is for demonstration purposes and shows how the mathematical operators can be realized.

B.1 Core Classes and Functions

```python
import numpy as np

class EpistemicState:
    def __init__(self, mu, sigma, delta, phi):
        self.mu = mu          # confidence [0,1]
        self.sigma = sigma    # uncertainty [0,1]
        self.delta = delta    # contradiction [0,1]
        self.phi = phi        # ontology tag (int or str)

    def __repr__(self):
        return f"EpistemicState(mu={self.mu:.2f}, sigma={self.sigma:.2f}, delta={self.delta:.2f}, phi={self.phi})"

class KnowledgeElement:
    def __init__(self, sid, text, time, causes, state):
        self.sid = sid
        self.text = text
        self.time = time
        self.causes = causes        # list of sids
        self.state = state

class CausalEpistemicGraph:
    def __init__(self):
        self.nodes = {}   # sid -> KnowledgeElement
        self.parents = {} # sid -> list of parent sids
        self.children = {}# sid -> list of child sids

    def add_node(self, element):
        self.nodes[element.sid] = element
        self.parents[element.sid] = element.causes
        for p in element.causes:
            self.children.setdefault(p, []).append(element.sid)

    def get_parents(self, sid):
        return [self.nodes[p] for p in self.parents.get(sid, [])]

def bayesian_update(prior_mu, prior_sigma, evidence_mu, evidence_sigma):
    """Combine prior and evidence as Gaussians."""
    prior_prec = 1.0 / (prior_sigma**2 + 1e-6)
    ev_prec = 1.0 / (evidence_sigma**2 + 1e-6)
    post_prec = prior_prec + ev_prec
    post_mu = (prior_mu * prior_prec + evidence_mu * ev_prec) / post_prec
    post_sigma = np.sqrt(1.0 / post_prec)
    return post_mu, post_sigma

def update_contradiction(delta, parent_states, evidence_delta=None):
    """Update contradiction score based on agreement among parents and new evidence."""
    # Simplified: take average disagreement among parents, then blend with evidence.
    # This is a placeholder; actual definition can be more sophisticated.
    if not parent_states:
        parent_agreement = 1.0  # no parents -> no disagreement
    else:
        # Average difference between parent mu's (high delta if they disagree)
        mus = [p.mu for p in parent_states]
        disagreements = [abs(mus[i] - mus[j]) for i in range(len(mus)) for j in range(i+1,len(mus))]
        parent_agreement = 1.0 - (np.mean(disagreements) if disagreements else 0.0)
    # Blend with evidence_delta if provided
    if evidence_delta is not None:
        new_delta = 0.7 * (1 - parent_agreement) + 0.3 * evidence_delta
    else:
        new_delta = 1 - parent_agreement
    return np.clip(new_delta, 0.0, 1.0)

def update_node(node, evidence_mu, evidence_sigma, evidence_delta=None):
    """Apply CES update to a single node given new evidence."""
    # Gather parent states
    parent_states = [p.state for p in graph.get_parents(node.sid)]
    # Update mu and sigma via Bayesian fusion with evidence
    new_mu, new_sigma = bayesian_update(node.state.mu, node.state.sigma, evidence_mu, evidence_sigma)
    # Update contradiction
    new_delta = update_contradiction(node.state.delta, parent_states, evidence_delta)
    node.state = EpistemicState(new_mu, new_sigma, new_delta, node.state.phi)
    return node.state

def apply_evidence(graph, evidence):
    """
    evidence: dict sid -> (mu, sigma, delta) for new observations.
    """
    for sid, (ev_mu, ev_sigma, ev_delta) in evidence.items():
        if sid in graph.nodes:
            update_node(graph.nodes[sid], ev_mu, ev_sigma, ev_delta)
        else:
            # Create new node if not present
            new_node = KnowledgeElement(sid, "", current_time, [], EpistemicState(ev_mu, ev_sigma, ev_delta, 0))
            graph.add_node(new_node)
