class StreamingScheduler:
    def __init__(self, ldvs, speech_encoder, text_decoder, speech_decoder, predictive_head,
                 cache_size=10, confidence_threshold=0.7):
        self.ldvs = ldvs
        self.speech_encoder = speech_encoder
        self.text_decoder = text_decoder
        self.speech_decoder = speech_decoder
        self.predictive_head = predictive_head
        self.cache = deque(maxlen=cache_size)
        self.confidence_threshold = confidence_threshold
        self.state = 'LISTENING'  # or 'SPEAKING'
        self.z = None  # current latent state
        self.partial_text = ""
    
    def listening_step(self, audio_chunk, incremental_text):
        """
        Process a 20ms audio chunk during listening.
        
        Returns:
            decoded_text_fragment: incremental text output
        """
        # Encode audio and update latent state
        u = self.speech_encoder(audio_chunk)
        self.z = self.ldvs.step(self.z, u)
        self.partial_text += incremental_text
        
        # Decode text incrementally
        text_out = self.text_decoder.streaming_decode(self.z[:, :d_c])
        
        # Predictive caching for future speech synthesis
        for tau_ms in [200, 300, 400, 500]:
            tau_steps = tau_ms // 20
            z_future = self.predictive_head(self.z, self.partial_text, tau_ms)
            speech_future = self.speech_decoder.generate(z_future)
            confidence = self.compute_confidence(z_future, self.partial_text)
            if confidence > self.confidence_threshold:
                self.cache.append({
                    'tau': tau_ms,
                    'speech': speech_future,
                    'confidence': confidence,
                    'context': self.partial_text[-50:]  # last few chars
                })
        
        return text_out
    
    def speaking_step(self, response_token):
        """
