D.3 Latent State Reset (LSR)

```python
def latent_state_reset(partial_transcript, target_speaker_id, vamprior, 
                       content_encoder, speaker_embedding, d_c=512, d_p=256, d_s=128, d_eps=128):
    """
    Resets the latent state at a turn boundary.
    
    Args:
        partial_transcript: string or token ids of the partial user utterance
        target_speaker_id: speaker ID for the system voice
        vamprior: Variational prior for prosody (learned Gaussian)
        content_encoder: Text encoder model
        speaker_embedding: Speaker embedding lookup table
    
    Returns:
        z: concatenated latent vector [d_z]
    """
    if partial_transcript is not None and len(partial_transcript) > 0:
        z_c = content_encoder(partial_transcript)  # [d_c]
    else:
        z_c = torch.zeros(d_c)
    
    z_p = vamprior.sample()  # [d_p]
    z_s = speaker_embedding(target_speaker_id)  # [d_s]
    z_eps = torch.zeros(d_eps)
    
    return torch.cat([z_c, z_p, z_s, z_eps], dim=-1)
```

D.4 Orthogonal Projection

```python
def orthogonalize(z_c, z_p, z_s, U_c, U_p, U_s):
    """
    Projects each latent component to be orthogonal to the subspaces spanned by the others.
    
    Args:
        z_c: [B, d_c] content vectors
        z_p: [B, d_p] prosody vectors
        z_s: [B, d_s] speaker vectors
        U_c, U_p, U_s: Orthonormal basis matrices for each subspace (learned via PCA)
    
    Returns:
        z_c_orth, z_p_orth, z_s_orth: Orthogonalized vectors
    """
    # Project content to be orthogonal to prosody and speaker subspaces
    z_c_orth = z_c - U_p @ (U_p.T @ z_c) - U_s @ (U_s.T @ z_c)
    
    # Project prosody orthogonal to content and speaker
    z_p_orth = z_p - U_c @ (U_c.T @ z_p) - U_s @ (U_s.T @ z_p)
    
    # Project speaker orthogonal to content and prosody
    z_s_orth = z_s - U_c @ (U_c.T @ z_s) - U_p @ (U_p.T @ z_s)
    
    return z_c_orth, z_p_orth, z_s_orth

def orthogonality_penalty(z_c, z_p, z_s):
    """
    Computes penalty for non-orthogonality between subspaces.
    """
    # Normalize vectors
    z_c_norm = F.normalize(z_c, dim=-1)
    z_p_norm = F.normalize(z_p, dim=-1)
    z_s_norm = F.normalize(z_s, dim=-1)
    
    # Cosine similarities
    cp_cos = torch.abs(torch.einsum('btd,btd->bt', z_c_norm, z_p_norm)).mean()
    cs_cos = torch.abs(torch.einsum('btd,btd->bt', z_c_norm, z_s_norm)).mean()
    ps_cos = torch.abs(torch.einsum('btd,btd->bt', z_p_norm, z_s_norm)).mean()
    
    return cp_cos + cs_cos + ps_cos
```

D.5 Contractive Penalty Computation

```python
def contractive_penalty(A_bar_matrices):
    """
    Computes penalty to enforce contractivity of SSM transition matrices.
    
    Args:
        A_bar_matrices: list of tensors, each of shape [B, d_z, d_z] or diagonal vectors [B, d_z]
    
    Returns:
        scalar penalty
    """
    penalty = 0.0
    for A in A_bar_matrices:
        if A.dim() == 3:  # full matrix
            # Compute spectral norm (largest singular value)
            spec_norm = torch.linalg.matrix_norm(A, ord=2)
        else:  # diagonal
            spec_norm = torch.max(torch.abs(A), dim=-1)[0]  # max absolute eigenvalue
        # Penalize if > 1 - delta
        delta = 0.01
        penalty += F.relu(spec_norm - (1 - delta)).mean()
    return penalty / len(A_bar_matrices)
```

