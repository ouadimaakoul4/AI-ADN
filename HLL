    """
    import numpy as np
    from scipy.spatial import KDTree
    
    T = T_init.copy()
    A = cloud_source['points']
    B = cloud_target['points']
    C_A = cloud_source['covariances']
    C_B = cloud_target['covariances']
    
    # Build KD-tree for target cloud
    tree = KDTree(B)
    
    for iter in range(max_iter):
        # Find correspondences
        distances, indices = tree.query(transform_points(A, T))
        
        # Compute residuals and combined covariances
        d = []
        C_combined = []
        valid_indices = []
        
        for i, (idx, dist) in enumerate(zip(indices, distances)):
            if dist < 10.0:  # outlier threshold
                d.append(B[idx] - transform_point(A[i], T))
                C_i = C_B[idx] + T[:3, :3] @ C_A[i] @ T[:3, :3].T
                C_combined.append(C_i)
                valid_indices.append(i)
        
        if len(valid_indices) < 10:
            break
        
        d = np.array(d)
        C_combined = np.array(C_combined)
        
        # Weighted least squares optimization
        def objective(delta):
            T_new = T.copy()
            T_new[:3, 3] += delta[:3]
            # Update rotation with small angle approximation
            R_delta = rotation_matrix(delta[3:])
            T_new[:3, :3] = R_delta @ T[:3, :3]
            
            residuals = []
            for i, idx in enumerate(valid_indices):
                resid = d[i] - (T_new[:3, 3] - T[:3, 3]) - \
                        (R_delta - np.eye(3)) @ transform_point(A[idx], T)[:3]
                residuals.append(resid)
            residuals = np.array(residuals)
            
            # Mahalanobis distance
            cost = 0
            for i in range(len(valid_indices)):
                cost += residuals[i] @ np.linalg.solve(C_combined[i], residuals[i])
            return cost
        
        # Solve for optimal update (simplified - in practice use Gauss-Newton)
        from scipy.optimize import minimize
        result = minimize(objective, np.zeros(6), method='BFGS')
        
        if not result.success:
            break
        
        delta = result.x
        T_new = T.copy()
        T_new[:3, 3] += delta[:3]
        R_delta = rotation_matrix(delta[3:])
        T_new[:3, :3] = R_delta @ T[:3, :3]
        
        # Check convergence
        if np.linalg.norm(T_new - T) < tol:
            T = T_new
            break
        
        T = T_new
    
    return T, iter < max_iter - 1
